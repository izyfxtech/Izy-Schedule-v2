  { time:'17:00', title:'Evening Walk or Light Activity', sub:'Weekend movement — keep the body moving', type:'t-move', duration:'45m', prep:false },
  { time:'17:45', title:'Freshen Up', sub:'Shower, change, transition to evening', type:'t-admin', duration:'30m', prep:false },
  { time:'18:15', title:'Dinner', sub:'Cook something you enjoy or dine out', type:'t-meal', duration:'1h 30m', prep:false },
  { time:'19:45', title:'Social or Entertainment', sub:'Friends, films, events, or hobbies', type:'t-life', duration:'2h 30m', prep:false },
  { time:'22:15', title:'Wind Down', sub:'No heavy content — ease into the end of the day', type:'t-admin', duration:'45m', prep:false },
  { time:'23:00', title:'Sleep', sub:'Rest well — Sunday is for recovery', type:'t-sleep', duration:'~7h 30m', prep:false },
];

const SUN_TEMPLATE = [
  { time:'08:00', title:'Wake Up', sub:'Rest day — gentle start', type:'t-admin', duration:'15m', prep:false },
  { time:'08:15', title:'Slow Morning Routine', sub:'No rushing — stretch, breathe, reflect', type:'t-life', duration:'45m', prep:false },
  { time:'09:00', title:'Breakfast', sub:'Leisurely, no screens if possible', type:'t-meal', duration:'45m', prep:false },
  { time:'09:45', title:'Light Exercise or Walk', sub:'Sunday movement — gentle, not a training session', type:'t-move', duration:'45m', prep:false },
  { time:'10:30', title:'Reading or Learning', sub:'Books, podcasts, or something that feeds the mind', type:'t-life', duration:'1h 30m', prep:false },
  { time:'12:00', title:'Lunch', sub:'Proper meal — cook or go somewhere nice', type:'t-meal', duration:'1h 30m', prep:false },
  { time:'13:30', title:'Rest or Nap', sub:'Recovery is productive — protect this', type:'t-free', duration:'1h', prep:false },
  { time:'14:30', title:'Hobby or Creative Time', sub:'Photography, music, writing — something purely for you', type:'t-life', duration:'2h', prep:false },
  { time:'16:30', title:'Social Time', sub:'Family, friends, or a call with someone important', type:'t-life', duration:'1h 30m', prep:false },
  { time:'18:00', title:'Dinner', sub:'Sunday dinner — the best meal of the week', type:'t-meal', duration:'1h 30m', prep:false },
  { time:'19:30', title:'Weekly Preview', sub:'Review next week\'s calendar, set top 3 priorities for Monday', type:'t-admin', duration:'45m', prep:false },
  { time:'20:15', title:'Prep for the Week', sub:'Clothes, bag, workspace — remove friction from Monday morning', type:'t-admin', duration:'30m', prep:false },
  { time:'20:45', title:'Wind Down', sub:'Light reading, journaling, or music — protect this window', type:'t-admin', duration:'1h 15m', prep:false },
  { time:'22:00', title:'Sleep', sub:'Early night — Sunday sleep sets the tone for the whole week', type:'t-sleep', duration:'~8h 30m', prep:false },
];

// ─────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────
const todayIdx = () => {
  const now = new Date();
  // The schedule day runs 05:00 → 04:59 next calendar day.
  // Before 5 AM we are still in yesterday's schedule (overnight Sleep block),
  // so treat as the previous calendar day.
  let d;
  if (now.getHours() < 5) {
    const prev = new Date(now);
    prev.setDate(prev.getDate() - 1);
    d = prev.getDay();
  } else {
    d = now.getDay();
  }
  return d === 0 ? 6 : d - 1;
};
let currentDay = todayIdx();
let weekData = {};
let editingIndex = null;
let toastTimer = null;
let clockInterval = null;
const undoStack = {}; // { [dayIndex]: blockArray } — one undo level per day

const clone = obj => JSON.parse(JSON.stringify(obj));

function getTemplate(i) {
  // 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri, 5=Sat, 6=Sun
  const templates = [MON_TEMPLATE, TUE_TEMPLATE, WED_TEMPLATE, THU_TEMPLATE, FRI_TEMPLATE, SAT_TEMPLATE, SUN_TEMPLATE];
  return clone(templates[i] || []);
}

// ─────────────────────────────────────────────────────
// MIDNIGHT BLOCK NORMALISATION
// ─────────────────────────────────────────────────────
// Moves blocks with times 00:00–05:59 to the next calendar day UNLESS the
// block carries earlyMorning:true. Uses two-pass to prevent cascading.
// Also deduplicates: if the target day already has a t-sleep block, an
// incoming overnight sleep block is dropped rather than duplicated.
function normalizeMidnightBlocks() {
  const additions = Array.from({ length: 7 }, () => []);

  for (let i = 0; i < 7; i++) {
    const nextDay = (i + 1) % 7;
    const remaining = [];
    for (const b of (weekData[i] || [])) {
      if (isOvernightTime(b.time) && !b.earlyMorning) {
        additions[nextDay].push(b);
      } else {
        remaining.push(b);
      }
    }
    weekData[i] = remaining;
  }

  for (let i = 0; i < 7; i++) {
    if (!additions[i].length) continue;
    const dayAlreadyHasSleep = (weekData[i] || []).some(b => b.type === 't-sleep');
    const toAdd = additions[i].filter(b => {
      // Drop overnight sleep blocks if the target day already has sleep
      if (b.type === 't-sleep' && dayAlreadyHasSleep) return false;
      return true;
    });
    if (toAdd.length) {
      weekData[i] = (weekData[i] || []).concat(toAdd);
    }
  }
}

// ─────────────────────────────────────────────────────
// STORAGE
// ─────────────────────────────────────────────────────

// Validates raw saved data — called on version mismatch before any template-filling
function validateRawData(data) {
  if (!data || typeof data !== 'object' || Array.isArray(data)) return false;
  // If every day is an empty array the user has no schedule — treat as needing reset
  // so new templates get applied rather than keeping a blank slate
  const totalBlocks = Object.values(data).reduce((sum, day) => sum + (Array.isArray(day) ? day.length : 0), 0);
  if (totalBlocks === 0) return false;
  for (let i = 0; i < 7; i++) {
    if (data[i] === undefined) continue;
    if (!Array.isArray(data[i])) return false;
    for (const b of data[i]) {
      if (!validateBlock(b)) return false;
    }
  }
  return true;
}

function loadFromStorage() {
  let storedVersion = null;
  try { storedVersion = localStorage.getItem(VERSION_KEY); } catch(e) {}

  // Read raw saved data — do NOT fill missing days yet
  let rawData = null;
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const parsed = JSON.parse(saved);
      if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {
        rawData = parsed;
      }
    }
  } catch(e) {}

  const currentMajor = parseMajor(APP_VERSION);
  const storedMajor  = parseMajor(storedVersion);
  let postInitToast = null;

  if (rawData === null) {
    // Genuine first visit — no saved data at all
    weekData = {};
    try { localStorage.setItem(VERSION_KEY, APP_VERSION); } catch(e) {}

  } else if (storedVersion === APP_VERSION) {
    // Exact match — trust the data, no action
    weekData = rawData;

  } else if (storedMajor === currentMajor) {
    // Same major, minor/patch change — keep data, silently update stamp
    weekData = rawData;
    try { localStorage.setItem(VERSION_KEY, APP_VERSION); } catch(e) {}

  } else {
    // Major version change — validate data, reset if incompatible
    if (validateRawData(rawData)) {
      weekData = rawData;
      try { localStorage.setItem(VERSION_KEY, APP_VERSION); } catch(e) {}
      if (storedVersion !== null) {
        postInitToast = 'App updated — your schedule has been kept ✓';
      }
    } else {
      weekData = {};
      try { localStorage.setItem(VERSION_KEY, APP_VERSION); } catch(e) {}
      if (storedVersion !== null) {
        postInitToast = 'App updated — schedule reset to defaults';
      }
    }
  }

  // Now fill any missing or empty days with the correct templates
  for (let i = 0; i < 7; i++) {
    if (!weekData[i] || !Array.isArray(weekData[i]) || weekData[i].length === 0) {
      weekData[i] = getTemplate(i);
    }
  }

  // If a reset happened, persist the fresh templates immediately
  if (postInitToast && postInitToast.includes('reset')) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(weekData)); } catch(e) {}
  }

  // Normalise any midnight blocks to their correct next-day position
  normalizeMidnightBlocks();

  // Sort every day
  for (let i = 0; i < 7; i++) {
    weekData[i].sort((a, b) => sortKey(a) - sortKey(b));
  }

  return postInitToast;
}

function saveSchedule() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(weekData));
    showToast('Saved ✓');
  } catch(e) {
    showToast('Save failed — storage unavailable');
  }
}

// Fix 6: Export — append anchor to DOM before click (required by Firefox), revoke after delay
function exportSchedule() {
  try {
    const json = JSON.stringify(weekData, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'weekly-schedule-backup.json';
    document.body.appendChild(a); // Fix 6: must be in DOM for Firefox
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000); // Fix 6: delay revoke so download can start
    showToast('Schedule exported ✓');
  } catch(e) {
    showToast('Export failed');
  }
}

// Fix 8: Validate individual block objects on import
function validateBlock(b) {
  if (!b || typeof b !== 'object') return false;
  if (typeof b.time !== 'string' || !/^\d{1,2}:\d{2}$/.test(b.time)) return false;
  const [hStr, mStr] = b.time.split(':');
  const h = parseInt(hStr, 10), m = parseInt(mStr, 10);
  if (h < 0 || h > 23 || m < 0 || m > 59) return false;
  if (typeof b.title !== 'string') return false;
  if (b.type !== undefined && typeof b.type !== 'string') return false;
  if (b.color !== undefined && (typeof b.color !== 'string' || !/^#[0-9a-f]{6}$/i.test(b.color))) return false;
  if (b.earlyMorning !== undefined && typeof b.earlyMorning !== 'boolean') return false;
  return true;
}

function importSchedule(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    event.target.value = ''; // Reset immediately so same file can be re-selected after any error
    try {
      const parsed = JSON.parse(e.target.result);
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
        showToast('Invalid file format'); return;
      }
      for (let i = 0; i < 7; i++) {
        if (parsed[i] === undefined) continue;
        if (!Array.isArray(parsed[i])) { showToast('Invalid schedule data — day ' + i + ' is not an array'); return; }
        for (const b of parsed[i]) {
          if (!validateBlock(b)) { showToast('Invalid block data in day ' + i + ' — import aborted'); return; }
        }
      }
      // Store for confirm overlay instead of browser confirm()
      pendingImportData = parsed;
      document.getElementById('importOverlay').classList.add('open');
    } catch(err) {
      showToast('Import failed — invalid JSON');
    }
  };
  reader.readAsText(file);
}

// ─────────────────────────────────────────────────────
// CLOCK
// ─────────────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  let h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
  const ap = h < 12 ? 'AM' : 'PM';
  const hr = h === 0 ? 12 : h > 12 ? h - 12 : h;
  document.getElementById('clockTime').textContent =
    `${String(hr).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')} ${ap}`;
  document.getElementById('clockDate').textContent =
    now.toLocaleDateString('en-US', { weekday:'long', month:'short', day:'numeric' });
}

// ─────────────────────────────────────────────────────
// NOW BANNER
// ─────────────────────────────────────────────────────
// timeToMins applies a +1440 offset for h<5 so midnight-crossing durations
// compare correctly. Boundary matches isOvernightTime (00:00–04:59).
function timeToMins(t) {
  if (!t) return 0;
  const parts = t.split(':').map(Number);
  const h = parts[0], m = parts[1];
  if (isNaN(h) || isNaN(m)) return 0;
  return h < 5 ? h * 60 + m + 1440 : h * 60 + m;
}

// Returns true if a time string falls in 00:00–04:59.
// 05:00+ is treated as legitimate early-morning (e.g. 5 AM wake-up on Mon/Fri).
// Only truly post-midnight times (00:00–04:59) are considered "next day" by default.
function isOvernightTime(t) {
  const h = parseInt((t || '').split(':')[0], 10);
  return !isNaN(h) && h >= 0 && h < 5;
}

// Sort comparator key — raw clock order, no overnight offset.
// Midnight blocks (00:00–05:59) live on the next day already, so they sort
// naturally at the top of that day.
function sortKey(block) {
  const parts = (block.time || '').split(':').map(Number);
  const h = parts[0], m = parts[1];
  if (isNaN(h) || isNaN(m)) return 0;
  return h * 60 + m;
}

// Returns blocks from the previous day that cross midnight into this day.
// Uses raw clock minutes (no overnight offset) against 1440 (midnight).
// A block starting at 22:00 lasting 8h ends at 06:00 — that crosses midnight,
// so 6h of remaining time appears at the top of the next day.
function getBleedIns(dayIdx) {
  const prevIdx = (dayIdx + 6) % 7;
  const MIDNIGHT = 1440;
  const result = [];
  for (const b of (weekData[prevIdx] || [])) {
    if (b.prep) continue;
    const dur = parseDurMins(b.duration);
    if (dur <= 0) continue;
    const [h, m] = (b.time || '').split(':').map(Number);
    if (isNaN(h) || isNaN(m)) continue;
    const rawStart = h * 60 + m;
    const rawEnd = rawStart + dur;
    if (rawEnd > MIDNIGHT) {
      result.push({ block: b, remainMins: rawEnd - MIDNIGHT, fromDay: prevIdx });
    }
  }
  return result;
}

function parseDurMins(str) {
  if (!str) return 0;
  if (/^→/.test(str)) return 0; // explicit continuation marker — no duration
  const s = str.replace(/^~/, '').trim(); // strip approximate prefix before parsing
  let mins = 0;
  const hm = s.match(/(\d+)h/); if (hm) mins += parseInt(hm[1]) * 60;
  const mm = s.match(/(\d+)m/); if (mm) mins += parseInt(mm[1]);
  return mins;
}

function fmt12(t) {
  if (!t) return '';
  const parts = t.split(':').map(Number);
  const h = parts[0], m = parts[1];
  if (isNaN(h) || isNaN(m)) return t; // Fix 4: return raw string rather than "NaN:NaN AM"
  const ap = h < 12 ? 'AM' : 'PM';
  const hr = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return `${hr}:${String(m).padStart(2,'0')} ${ap}`;
}

function updateNowBanner() {
  const today = todayIdx();
  const banner = document.getElementById('nowBanner');

  if (currentDay !== today) {
    banner.style.display = 'none';
    return;
  }

  banner.style.display = 'block';
  const blocks = (weekData[currentDay] || []).slice().sort((a, b) => sortKey(a) - sortKey(b));
  const now = new Date();
  const rawH = now.getHours(), rawM = now.getMinutes();
  const nm = rawH < 6 ? rawH * 60 + rawM + 1440 : rawH * 60 + rawM;

  let active = null, next = null;
  for (const b of blocks) {
    if (b.prep) continue;
    const start = timeToMins(b.time);
    const dur = parseDurMins(b.duration);
    if (dur > 0) {
      const end = start + dur;
      const isCurr = nm >= start && nm < end;
      if (isCurr && !active) { active = b; continue; }
    }
    if (!next) {
      const activeEnd = active ? timeToMins(active.time) + parseDurMins(active.duration) : nm;
      if (start >= activeEnd && start > nm) { next = b; }
    }
  }

  const nowTitleEl  = document.getElementById('nowTitle');
  const nowSubEl    = document.getElementById('nowSub');
  const nextTitleEl = document.getElementById('nextTitle');
  const nextSubEl   = document.getElementById('nextSub');
  const nowPanel    = document.querySelector('.now-panel:first-child');
  const nextPanel   = document.querySelector('.now-panel:last-child');

  if (active) {
    nowTitleEl.innerHTML = `<span class="glow-dot"></span>${escHtml(active.title)}`;
    nowTitleEl.style.color = 'var(--trade)';
    nowSubEl.textContent = `${fmt12(active.time)} · ${active.duration || ''}`;
    nowPanel.classList.add('is-linked');
    nowPanel.onclick = () => scrollToBlock(active.time);
  } else {
    nowTitleEl.innerHTML = 'No scheduled block right now';
    nowTitleEl.style.color = 'var(--dim)';
    nowSubEl.textContent = '';
    nowPanel.classList.remove('is-linked');
    nowPanel.onclick = null;
  }

  if (next) {
    nextTitleEl.textContent = next.title;
    nextTitleEl.style.color = 'var(--muted)';
    nextSubEl.textContent = `Starts at ${fmt12(next.time)} · ${next.duration || ''}`;
    nextPanel.classList.add('is-linked');
    nextPanel.onclick = () => scrollToBlock(next.time);
  } else {
    nextTitleEl.textContent = 'No more blocks today';
    nextTitleEl.style.color = 'var(--dim)';
    nextSubEl.textContent = '';
    nextPanel.classList.remove('is-linked');
    nextPanel.onclick = null;
  }
}

function scrollToBlock(time) {
  const row = document.querySelector(`.block-row[data-time="${CSS.escape(time)}"]`);
  if (!row) return;
  row.scrollIntoView({ behavior: 'smooth', block: 'center' });
  const content = row.querySelector('.block-content');
  if (!content) return;
  content.classList.remove('block-flash');
  void content.offsetWidth;
  content.classList.add('block-flash');
  content.addEventListener('animationend', () => content.classList.remove('block-flash'), { once: true });
}

// Jump to the origin day and highlight the source block of a bleed-in
function jumpToBleedSource(dayIdx, time) {
  switchDay(dayIdx);
  setTimeout(() => scrollToBlock(time), 120);
}

// ─────────────────────────────────────────────────────
// RENDER
// ─────────────────────────────────────────────────────
function renderTabs() {
  const today = todayIdx();
  const container = document.getElementById('dayTabs');
  container.innerHTML = '';
  DAYS.forEach((day, i) => {
    const btn = document.createElement('button');
    btn.className = 'day-tab'
      + (WEEKEND_IDS.includes(i) ? ' weekend' : '')
      + (i === currentDay ? ' active' : '');
    btn.innerHTML = day.slice(0,3) + (i === today ? '<span class="today-dot"></span>' : '');
    btn.onclick = () => switchDay(i);
    container.appendChild(btn);
  });
}

// Fix 7: whitelist of valid CSS type classes
const VALID_TYPES = new Set(['t-sleep','t-trade','t-meal','t-move','t-life','t-admin','t-study','t-free']);
function safeType(t) { return VALID_TYPES.has(t) ? t : 't-free'; }

function renderSchedule() {
  const blocks = (weekData[currentDay] || []).slice().sort((a, b) => sortKey(a) - sortKey(b));
  const body = document.getElementById('scheduleBody');
  body.innerHTML = '';

  document.getElementById('toolbarDay').textContent = DAYS[currentDay];
  document.getElementById('toolbarType').textContent = '· ' + (WEEKEND_IDS.includes(currentDay) ? 'Weekend' : 'Weekday');

  const today = todayIdx();
  const _now = new Date();
  const rawH = _now.getHours(), rawM = _now.getMinutes();
  const nm = rawH < 6 ? rawH * 60 + rawM + 1440 : rawH * 60 + rawM;

  // Only pulse the single next upcoming prep bar — not every one
  const nextPrepIdx = (currentDay === today)
    ? blocks.findIndex(b => b.prep && timeToMins(b.time) > nm)
    : -1;

  // ── Bleed-in: blocks from the previous day that run past midnight ──
  const bleedIns = getBleedIns(currentDay);
  bleedIns.forEach(({ block: src, remainMins, fromDay }) => {
    const h = Math.floor(remainMins / 60), m = remainMins % 60;
    const remStr = (h > 0 ? `${h}h ` : '') + (m > 0 ? `${m}m` : '');
    const row = document.createElement('div');
    row.className = 'block-row bleed-in-row';
    row.dataset.time = '00:00';
    const typeClass = safeType(src.type);
    let colorStyle = '';
    if (src.color) {
      const { r, g, b } = hexToRgb(src.color);
      colorStyle = `style="border-left-color:${src.color};background:rgba(${r},${g},${b},0.05)"`;
    }
    row.innerHTML = `
      <div class="time-col"><span class="time-label" style="opacity:0.45">00:00</span></div>
      <div class="block-content ${typeClass} bleed-in-block" ${colorStyle}
           onclick="jumpToBleedSource(${fromDay}, '${escHtml(src.time)}')"
           title="Continued from ${DAYS[fromDay]} — click to go to source">
        <span class="bleed-tag">↩ Continued from ${escHtml(DAYS[fromDay])}</span>
        <span class="block-title">${escHtml(src.title)}</span>
        <div class="block-sub">Remaining: ${escHtml(remStr)}</div>
        <span class="block-duration">${escHtml(remStr)}</span>
      </div>`;
    body.appendChild(row);
  });

  blocks.forEach((block, idx) => {
    // Prep row
    if (block.prep) {
      const isNextPrep = idx === nextPrepIdx;
      const row = document.createElement('div');
      row.className = 'prep-row';
      row.innerHTML = `
        <div class="prep-spacer"><span class="prep-time">${escHtml(fmt12(block.time))}</span></div>
        <div class="prep-bar" onclick="openModal(${idx})">
          <span class="prep-pulse" style="${isNextPrep ? '' : 'animation:none;opacity:0.4'}">◉</span>
          ${escHtml(block.sub || 'Prepare for candle close — be at charts')}
        </div>`;
      body.appendChild(row);
      return;
    }

    // Hour separator: show when current block's hour differs from previous non-prep block's hour
    if (idx > 0) {
      const prevBlock = blocks.slice(0, idx).reverse().find(b => !b.prep);
      if (prevBlock && block.time && block.time.endsWith(':00')) {
        const prevHour = prevBlock.time ? prevBlock.time.split(':')[0] : null;
        const curHour  = block.time.split(':')[0];
        if (prevHour !== curHour) {
          const sep = document.createElement('div');
          sep.className = 'hour-sep';
          body.appendChild(sep);
        }
      }
    }

    // Fix 1: Is this the active block? Use adjusted mins
    let isCurr = false;
    if (currentDay === today) {
      const start = timeToMins(block.time);
      const dur = parseDurMins(block.duration);
      if (dur > 0) {
        isCurr = nm >= start && nm < start + dur;
      }
    }

    const row = document.createElement('div');
    row.className = 'block-row';
    row.dataset.time = block.time;
    if (isCurr) row.classList.add('is-current-block');
    const typeClass = safeType(block.type);
    // Per-block colour: border-left uses the colour, background gets a very faint tint
    let colorStyle = '';
    if (block.color) {
      const { r, g, b } = hexToRgb(block.color);
      colorStyle = `style="border-left-color:${block.color};background:rgba(${r},${g},${b},0.07)"`;
    }
    row.innerHTML = `
      <div class="time-col"><span class="time-label">${escHtml(fmt12(block.time))}</span></div>
      <div class="block-content ${typeClass} ${isCurr ? 'current-block' : ''}" ${colorStyle} onclick="openModal(${idx})">
        ${isCurr ? '<span class="now-tag">◉ Now</span>' : ''}
        <span class="block-title">${escHtml(block.title)}</span>
        ${block.sub ? `<div class="block-sub">${escHtml(block.sub)}</div>` : ''}
        <span class="block-duration">${escHtml(block.duration || '')}</span>
        <button class="block-edit-btn" onclick="event.stopPropagation();openModal(${idx})">✎</button>
      </div>`;
    body.appendChild(row);
  });

  updateNowBanner();
}

// Fix 1: Lightweight per-second "Now" badge sync — triggers full re-render only when
// the active block changes. Prep blocks render as .prep-row (not .block-row), so we
// track domRowIdx separately so data index and DOM index stay correctly aligned.
function syncNowBadge() {
  const today = todayIdx();
  if (currentDay !== today) return;
  const blocks = (weekData[currentDay] || []).slice().sort((a, b) => sortKey(a) - sortKey(b));
  const rawH = new Date().getHours(), rawM = new Date().getMinutes();
  const nm = rawH < 6 ? rawH * 60 + rawM + 1440 : rawH * 60 + rawM;
  const domRows = document.querySelectorAll('.block-row');

  let needsFullRender = false;
  let domRowIdx = 0;
  for (let i = 0; i < blocks.length; i++) {
    const block = blocks[i];
    if (block.prep) continue; // prep = .prep-row, not .block-row — skip without incrementing
    const row = domRows[domRowIdx++];
    if (!row) continue;
    const start = timeToMins(block.time);
    const dur = parseDurMins(block.duration);
    const shouldBeActive = dur > 0 && nm >= start && nm < start + dur;
    const wasActive = row.classList.contains('is-current-block');
    if (shouldBeActive !== wasActive) { needsFullRender = true; break; }
  }
  if (needsFullRender) renderSchedule();
}

function escHtml(str) {
  return String(str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}

// ─────────────────────────────────────────────────────
// NAVIGATION
// ─────────────────────────────────────────────────────
function switchDay(idx) {
  currentDay = idx;
  renderTabs();
  renderSchedule();
  syncUndoButton();
  syncSaveDefaultButton();
}

// ─────────────────────────────────────────────────────
// MODAL HELPERS
// ─────────────────────────────────────────────────────
function showModalError(msg) {
  const el = document.getElementById('modalError');
  el.textContent = msg;
  el.classList.add('show');
}
function clearModalError() {
  document.getElementById('modalError').classList.remove('show');
  document.getElementById('overlapWarning').classList.remove('show');
}

function armDelete() {
  // Show inline delete confirm banner, hide normal footer actions
  document.getElementById('deleteConfirmBanner').classList.add('show');
  document.getElementById('footerActions').style.display = 'none';
}
function cancelDeleteArm() {
  document.getElementById('deleteConfirmBanner').classList.remove('show');
  document.getElementById('footerActions').style.display = '';
}

let pendingOverlapBlock = null;
let pendingOverlapTargetDay = null;
function showOverlapWarning(conflicts, block, targetDay) {
  pendingOverlapBlock = block;
  pendingOverlapTargetDay = targetDay;
  const msg = document.getElementById('overlapMsg');
  const list = document.getElementById('overlapList');
  msg.textContent = `Overlaps with ${conflicts.length} existing block${conflicts.length > 1 ? 's' : ''}:`;
  list.textContent = conflicts.map(b => `${b.time} — ${b.title} (${b.duration})`).join(' · ');
  document.getElementById('overlapWarning').classList.add('show');
  document.getElementById('footerActions').style.display = 'none';
}
function dismissOverlap() {
  document.getElementById('overlapWarning').classList.remove('show');
  document.getElementById('footerActions').style.display = '';
  pendingOverlapBlock = null;
  pendingOverlapTargetDay = null;
}
function saveBlockForce() {
  if (!pendingOverlapBlock) return;
  const td = pendingOverlapTargetDay !== null ? pendingOverlapTargetDay : currentDay;
  commitBlock(pendingOverlapBlock, td);
  dismissOverlap();
}

function showImportConfirm() {
  document.getElementById('importPreConfirm').classList.add('open');
}
function closeImportPreConfirm() {
  document.getElementById('importPreConfirm').classList.remove('open');
}
function proceedToFilePicker() {
  closeImportPreConfirm();
  document.getElementById('importFile').click();
}

document.getElementById('importPreConfirm').addEventListener('click', function(e) {
  if (e.target === this) closeImportPreConfirm();
});

let pendingImportData = null;
function closeImportConfirm() {
  document.getElementById('importOverlay').classList.remove('open');
  pendingImportData = null;
}
function confirmImport() {
  if (!pendingImportData) return;
  weekData = pendingImportData;
  for (let i = 0; i < 7; i++) {
    if (!weekData[i]) weekData[i] = getTemplate(i);
    // Sort each day so overnight/out-of-order blocks from the file land correctly
    weekData[i].sort((a, b) => sortKey(a) - sortKey(b));
  }
  normalizeMidnightBlocks();
  try {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(weekData)); } catch(e) {}
    // Stamp the current app version so the version check on next load doesn't
    // re-evaluate (and potentially reset) the data we just imported
    localStorage.setItem(VERSION_KEY, APP_VERSION);
  } catch(e) {
    showToast('Imported (storage unavailable)');
    renderTabs(); renderSchedule(); syncUndoButton(); syncSaveDefaultButton();
    closeImportConfirm(); return;
  }
  renderTabs();
  renderSchedule();
  syncUndoButton();
  syncSaveDefaultButton();
  showToast('Schedule imported ✓');
  closeImportConfirm();
  pushToCloud();
}

document.getElementById('importOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeImportConfirm();
});

// ─────────────────────────────────────────────────────
// COLOUR PICKER
// ─────────────────────────────────────────────────────
let _selectedColor = null;

function selectSwatch(color) {
  _selectedColor = color || null;
  // Update swatch selection states
  document.getElementById('swatchNone').classList.toggle('selected', !color);
  document.querySelectorAll('.color-swatch').forEach(s => {
    s.classList.toggle('selected', s.dataset.color === color);
  });
  // Sync the custom colour input value if a preset was clicked
  if (color && /^#[0-9a-f]{6}$/i.test(color)) {
    document.getElementById('colorCustom').value = color;
  }
}

function hexToRgb(hex) {
  if (!hex || !/^#[0-9a-f]{6}$/i.test(hex)) return { r: 128, g: 128, b: 128 };
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return { r, g, b };
}

// ─────────────────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────────────────
function openModal(sortedIdx) {
  // renderSchedule renders from a sorted copy; resolve sortedIdx back to the
  // actual position in weekData[currentDay] so we edit the correct block.
  const sortedBlocks = (weekData[currentDay] || []).slice().sort((a, b) => sortKey(a) - sortKey(b));
  let resolvedIdx = null;
  if (sortedIdx !== null) {
    const target = sortedBlocks[sortedIdx];
    if (target) {
      resolvedIdx = weekData[currentDay].indexOf(target);
      if (resolvedIdx === -1) resolvedIdx = null;
    }
  }
  editingIndex = resolvedIdx;
  const isNew = resolvedIdx === null;
  document.getElementById('modalTitle').textContent = isNew ? 'Add Block' : 'Edit Block';
  document.getElementById('deleteBtn').style.display = isNew ? 'none' : '';
  document.getElementById('deleteConfirmBanner').classList.remove('show');
  document.getElementById('footerActions').style.display = '';

  if (isNew) {
    document.getElementById('fTime').value = '08:00';
    document.getElementById('fDuration').value = '';
    document.getElementById('fTitle').value = '';
    document.getElementById('fSub').value = '';
    document.getElementById('fType').value = 't-free';
    document.getElementById('fIsPrep').checked = false;
    selectSwatch(null);
  } else {
    const b = weekData[currentDay][resolvedIdx];
    document.getElementById('fTime').value = b.time || '';
    document.getElementById('fDuration').value = b.duration || '';
    document.getElementById('fTitle').value = b.title || '';
    document.getElementById('fSub').value = b.sub || '';
    document.getElementById('fType').value = safeType(b.type);
    document.getElementById('fIsPrep').checked = !!b.prep;
    selectSwatch(b.color || null);
  }

  clearModalError();
  document.getElementById('saveBtn').style.display = '';
  pendingOverlapBlock = null;

  document.getElementById('modalOverlay').classList.add('open');
  // Fix A: new blocks → focus Start Time (first field); editing → focus Title
  setTimeout(() => {
    if (resolvedIdx === null) {
      document.getElementById('fTime').focus();
    } else {
      document.getElementById('fTitle').focus();
    }
  }, 80);
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.getElementById('fType').disabled = false;
  document.getElementById('deleteConfirmBanner').classList.remove('show');
  document.getElementById('footerActions').style.display = '';
  document.getElementById('saveBtn').style.display = '';
  document.getElementById('overlapWarning').classList.remove('show');
  document.getElementById('dayPickerBanner').classList.remove('show');
  _pendingBlock = null;
  pendingOverlapBlock = null;
  clearModalError();
  selectSwatch(null);
  editingIndex = null;
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

function saveBlock() {
  clearModalError();
  const time     = document.getElementById('fTime').value;
  const duration = document.getElementById('fDuration').value.trim();
  const title    = document.getElementById('fTitle').value.trim();
  const sub      = document.getElementById('fSub').value.trim();
  const type     = document.getElementById('fType').value;
  const isPrep   = document.getElementById('fIsPrep').checked;

  if (!time) { showModalError('Please enter a start time.'); return; }
  if (!title && !isPrep) { showModalError('Please enter a title.'); return; }

  if (duration) {
    const isArrow    = /^→/.test(duration);
    const isApprox   = /^~/.test(duration);
    const baseStr    = isApprox ? duration.slice(1).trim() : duration.trim();
    const isValidDur = /^(\d+h\s*)?(\d+m)?$/.test(baseStr) && baseStr !== '';
    if (!isArrow && !isValidDur) {
      showModalError('Invalid duration. Use: 45m · 1h · 1h 30m · or prefix ~ for approximate (e.g. ~1h 30m).');
      return;
    }
  }

  const block = { time, title, sub, type: safeType(type), duration, prep: isPrep, color: _selectedColor || undefined };

  // ── Overnight time routing (00:00–05:59) ──────────────────────────────
  if (!isPrep && isOvernightTime(time)) {
    const today    = todayIdx();
    const nextDay  = (currentDay + 1) % 7;

    if (currentDay === today) {
      // Editing today's tab — check if block time has already passed in real time
      const nowH = new Date().getHours(), nowM = new Date().getMinutes();
      const nowRaw  = nowH * 60 + nowM;
      const blockRaw = parseInt(time.split(':')[0]) * 60 + parseInt(time.split(':')[1]);

      if (nowRaw > blockRaw) {
        // Case 1: time has already passed — unambiguously tomorrow, auto-route with toast+undo
        runOverlapAndCommit(block, nextDay, true);
        return;
      }
    }

    // Case 2 (editing today, time not yet passed) and Case 3 (editing another day) — ask
    _pendingBlock = block;
    document.getElementById('dayPickerMsg').textContent =
      `${fmt12(time)} is past midnight. Should this go on ${DAYS[currentDay]} (early morning) or ${DAYS[nextDay]} (end of ${DAYS[currentDay]})?`;
    document.getElementById('dayPickerThisDay').textContent = `Early ${DAYS[currentDay]}`;
    document.getElementById('dayPickerNextDay').textContent = `End of ${DAYS[currentDay]} → ${DAYS[nextDay]}`;
    document.getElementById('dayPickerBanner').classList.add('show');
    document.getElementById('footerActions').style.display = 'none';
    return;
  }

  runOverlapAndCommit(block, currentDay);
}

// ── Pending block for day-picker ──────────────────────────────────────────
let _pendingBlock = null;

function dismissDayPicker() {
  document.getElementById('dayPickerBanner').classList.remove('show');
  document.getElementById('footerActions').style.display = '';
  _pendingBlock = null;
}

function commitWithDay(which) {
  if (!_pendingBlock) return;
  const nextDay = (currentDay + 1) % 7;
  const targetDay = which === 'next' ? nextDay : currentDay;
  // Mark explicitly early-morning blocks so normalizeMidnightBlocks won't migrate them
  const block = which === 'this'
    ? { ..._pendingBlock, earlyMorning: true }
    : { ..._pendingBlock, earlyMorning: undefined };
  dismissDayPicker();
  runOverlapAndCommit(block, targetDay);
}

function runOverlapAndCommit(block, targetDay, autoRouted = false) {
  // Overlap check against the target day
  if (!block.prep) {
    const blocks   = weekData[targetDay];
    const newStart = timeToMins(block.time);
    const newDur   = parseDurMins(block.duration);
    const newEnd   = newDur > 0 ? newStart + newDur : null;
    const skipIdx  = (targetDay === currentDay) ? editingIndex : -1;
    const conflicts = [];
    for (let i = 0; i < blocks.length; i++) {
      if (i === skipIdx) continue;
      const b = blocks[i];
      if (b.prep || !b.duration || parseDurMins(b.duration) === 0) continue;
      const bStart = timeToMins(b.time);
      const bEnd   = bStart + parseDurMins(b.duration);
      if (newEnd !== null) {
        if (newStart < bEnd && newEnd > bStart) conflicts.push(b);
      } else {
        if (newStart >= bStart && newStart < bEnd) conflicts.push(b);
      }
    }
    if (conflicts.length > 0) {
      showOverlapWarning(conflicts, block, targetDay);
      return;
    }
  }
  commitBlock(block, targetDay, autoRouted);
}

function commitBlock(block, targetDay, autoRouted = false) {
  if (targetDay === undefined) targetDay = currentDay;
  const isNew    = editingIndex === null;
  const crossDay = targetDay !== currentDay;

  undoStack[currentDay] = clone(weekData[currentDay]);
  if (crossDay) undoStack[targetDay] = clone(weekData[targetDay]);

  if (isNew) {
    weekData[targetDay].push(block);
  } else {
    if (crossDay) {
      weekData[currentDay].splice(editingIndex, 1);
      weekData[targetDay].push(block);
    } else {
      weekData[currentDay][editingIndex] = block;
    }
  }

  weekData[targetDay].sort((a, b) => sortKey(a) - sortKey(b));
  if (crossDay) weekData[currentDay].sort((a, b) => sortKey(a) - sortKey(b));

  cloudSave();
  closeModal();
  renderSchedule();
  syncUndoButton();

  if (autoRouted) {
    // Case 1: auto-routed past midnight — toast with undo so user can correct if needed
    showToast(`Auto-moved to ${DAYS[targetDay]} ✓`, true);
  } else if (crossDay) {
    showToast(`${isNew ? 'Added' : 'Moved'} to ${DAYS[targetDay]} ✓`, true);
  } else {
    showToast(isNew ? 'Block added ✓' : 'Block saved ✓');
  }
}

function deleteBlock() {
  if (editingIndex === null) return;
  undoStack[currentDay] = clone(weekData[currentDay]);
  weekData[currentDay].splice(editingIndex, 1);
  cloudSave();
  closeModal();
  renderSchedule();
  syncUndoButton();
  showToast('Block deleted', true);
}

function undoLastAction() {
  // Use the day that was active when the action happened (captured in _toastUndoDay),
  // falling back to currentDay for toolbar-button clicks where no toast day is set.
  const targetDay = (_toastUndoDay !== null) ? _toastUndoDay : currentDay;
  if (!undoStack[targetDay]) { showToast('Nothing to undo'); return; }
  weekData[targetDay] = undoStack[targetDay];
  delete undoStack[targetDay];
  _toastUndoDay = null;
  cloudSave();
  // If the undo was for a different day, switch to it so the user sees the change.
  if (targetDay !== currentDay) {
    currentDay = targetDay;
    renderTabs();
  }
  renderSchedule();
  syncUndoButton();
  document.getElementById('toast').classList.remove('show');
  showToast('Undo ✓');
}

function syncUndoButton() {
  const btn = document.getElementById('undoBtn');
  if (!btn) return;
  const hasUndo = !!undoStack[currentDay];
  btn.disabled = !hasUndo;
  btn.classList.toggle('has-undo', hasUndo);
}

// ─────────────────────────────────────────────────────
// USER DEFAULTS
// ─────────────────────────────────────────────────────
function loadUserDefaults() {
  try {
    const saved = localStorage.getItem(USER_DEFAULT_KEY);
    return saved ? JSON.parse(saved) : {};
  } catch(e) { return {}; }
}

function saveUserDefaults(defaults) {
  try { localStorage.setItem(USER_DEFAULT_KEY, JSON.stringify(defaults)); } catch(e) {}
  // Push only the user_defaults field rather than re-serialising all of weekData
  if (!_sbUser || !_sb) return;
  clearTimeout(_pushTimer);
  _pushTimer = setTimeout(pushToCloud, 600);
}

function getUserDefault(dayIdx) {
  const defaults = loadUserDefaults();
  return defaults[dayIdx] || null;
}

function saveAsDefault() {
  const defaults = loadUserDefaults();
  defaults[currentDay] = clone(weekData[currentDay]);
  saveUserDefaults(defaults);
  syncSaveDefaultButton();
  showToast(`${DAYS[currentDay]} default saved ✓`);
}

function clearUserDefault() {
  const defaults = loadUserDefaults();
  delete defaults[currentDay];
  saveUserDefaults(defaults);
  closeResetConfirm();
  syncSaveDefaultButton();
  showToast('Custom default cleared — factory template will be used');
}

function syncSaveDefaultButton() {
  const btn = document.getElementById('saveDefaultBtn');
  if (!btn) return;
  const hasCustom = !!getUserDefault(currentDay);
  btn.textContent = hasCustom ? '✎ Update Default' : 'Save as Default';
  btn.classList.toggle('btn-primary', hasCustom);
}

// ─────────────────────────────────────────────────────
// RESET
// ─────────────────────────────────────────────────────
function showResetConfirm() {
  document.getElementById('resetDayName').textContent = DAYS[currentDay];
  const hasCustom = !!getUserDefault(currentDay);
  const msg = document.getElementById('resetMsg');
  const clearBtn = document.getElementById('clearDefaultBtn');

  if (hasCustom) {
    msg.innerHTML = `This will restore your <strong>saved custom default</strong> for <strong id="resetDayName">${DAYS[currentDay]}</strong>. Current changes will be lost.`;
    clearBtn.style.display = '';
  } else {
    msg.innerHTML = `This will restore the <strong>factory template</strong> for <strong id="resetDayName">${DAYS[currentDay]}</strong>. Your saved changes will be lost.`;
    clearBtn.style.display = 'none';
  }
  document.getElementById('resetOverlay').classList.add('open');
}
function closeResetConfirm() {
  document.getElementById('resetOverlay').classList.remove('open');
}
function confirmReset() {
  undoStack[currentDay] = clone(weekData[currentDay]);
  const userDefault = getUserDefault(currentDay);
  weekData[currentDay] = userDefault ? clone(userDefault) : getTemplate(currentDay);
  cloudSave();
  closeResetConfirm();
  renderSchedule();
  syncUndoButton();
  showToast(userDefault ? 'Reset to your custom default ✓' : 'Reset to factory template ✓', true);
}

// Close reset overlay on outside click
document.getElementById('resetOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeResetConfirm();
});

// ─────────────────────────────────────────────────────
// TOAST
// ─────────────────────────────────────────────────────
let _toastUndoDay = null; // day index captured at the moment the undo-toast was shown

function showToast(msg, withUndo = false) {
  const t = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  const undoBtn = document.getElementById('toastUndoBtn');
  undoBtn.style.display = withUndo ? '' : 'none';
  // Capture the current day so Undo always targets the day the action happened on,
  // even if the user switches tabs before the toast times out.
  _toastUndoDay = withUndo ? currentDay : null;
  t.classList.add('show');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), withUndo ? 5000 : 2500);
}

// ─────────────────────────────────────────────────────
// KEYBOARD
// ─────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (document.getElementById('modalOverlay').classList.contains('open')) { closeModal(); }
    else if (document.getElementById('resetOverlay').classList.contains('open')) { closeResetConfirm(); }
    else if (document.getElementById('importOverlay').classList.contains('open')) { closeImportConfirm(); }
    else if (document.getElementById('importPreConfirm').classList.contains('open')) { closeImportPreConfirm(); }
  }
});

// ─────────────────────────────────────────────────────
// THEMES
// ─────────────────────────────────────────────────────
const ACCENTS    = ['espresso', 'terminal', 'slate', 'midnight', 'crimson', 'arctic', 'dusk'];
const BRIGHTNESS = ['espresso', 'dark', 'light', 'warm'];
const ACCENT_KEY     = 'iz-accent-v1';
const BRIGHTNESS_KEY = 'iz-brightness-v1';

function applyAccent(name) {
  const accent = ACCENTS.includes(name) ? name : 'espresso';
  if (accent === 'espresso') {
    document.documentElement.removeAttribute('data-accent');
  } else {
    document.documentElement.setAttribute('data-accent', accent);
  }
  document.querySelectorAll('.theme-swatch').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.accent === accent);
  });
  try { localStorage.setItem(ACCENT_KEY, accent); } catch(e) {}
  cloudSave();
}

function applyBrightness(name) {
  const b = BRIGHTNESS.includes(name) ? name : 'espresso';
  if (b === 'espresso') {
    document.documentElement.removeAttribute('data-brightness');
  } else {
    document.documentElement.setAttribute('data-brightness', b);
  }
  document.querySelectorAll('.brightness-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.brightness === b);
  });
  try { localStorage.setItem(BRIGHTNESS_KEY, b); } catch(e) {}
  cloudSave();
}

function loadTheme() {
  let accent = 'espresso', brightness = 'espresso';
  try { accent     = localStorage.getItem(ACCENT_KEY)     || 'espresso'; } catch(e) {}
  try { brightness = localStorage.getItem(BRIGHTNESS_KEY) || 'espresso'; } catch(e) {}

  applyAccent(accent);
  applyBrightness(brightness);
}

// ─────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────
loadTheme();
const _postInitToast = loadFromStorage();
renderTabs();
renderSchedule();
syncUndoButton();
syncSaveDefaultButton();
updateClock();
if (_postInitToast) showToast(_postInitToast);

let _lastRenderedDay = todayIdx();

// Store interval refs for potential cleanup
clockInterval = setInterval(() => {
  updateClock();
  syncNowBadge();
  // Detect schedule-day rollover (fires at 06:00, not midnight)
  const currentTodayIdx = todayIdx();
  if (currentTodayIdx !== _lastRenderedDay) {
    // If the user was viewing the old "today", advance them to the new day automatically
    if (currentDay === _lastRenderedDay) currentDay = currentTodayIdx;
    _lastRenderedDay = currentTodayIdx;
    renderTabs();
    renderSchedule();
  } else {
    // Keep the Now banner ticking on today's tab without a full re-render
    updateNowBanner();
  }
}, 1000);

// Full re-render every 5 minutes as safety net
const renderInterval = setInterval(() => renderSchedule(), 300000);

// Cleanup intervals when page is closed/navigated away
window.addEventListener('beforeunload', () => {
  clearInterval(clockInterval);
  clearInterval(renderInterval);
  cancelAllNotifications();
});

// ─────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────
const NOTIF_KEY = 'iz-notifications-enabled';
let _notifTimers = [];

function notificationsEnabled() {
  try { return localStorage.getItem(NOTIF_KEY) === 'true'; } catch(e) { return false; }
}

function setNotificationsEnabled(val) {
  try { localStorage.setItem(NOTIF_KEY, val ? 'true' : 'false'); } catch(e) {}
}

function cancelAllNotifications() {
  _notifTimers.forEach(id => clearTimeout(id));
  _notifTimers = [];
}

// Schedule browser notifications for all upcoming blocks today
function scheduleNotifications() {
  cancelAllNotifications();
  if (!notificationsEnabled()) return;
  if (Notification.permission !== 'granted') return;

  const today = todayIdx();
  const blocks = weekData[today] || [];
  const now = new Date();
  const rawH = now.getHours(), rawM = now.getMinutes(), rawS = now.getSeconds();
  // Use the same offset logic as timeToMins so overnight blocks compare correctly
  const nowMins = rawH < 6 ? rawH * 60 + rawM + 1440 : rawH * 60 + rawM;

  blocks.forEach(block => {
    const blockMins = timeToMins(block.time);
    // minsUntil measured from the start of the current minute
    const minsUntilStart = blockMins - nowMins;
    const msUntil = minsUntilStart * 60 * 1000 - rawS * 1000; // account for elapsed seconds
    if (msUntil <= 0) return; // block has already started or passed

    const icon = '/Izy-Schedule-v2/icons/icon-192.png';
    // Notify exactly at block start
    const id = setTimeout(() => {
      if (block.prep) {
        showNotification(
          '◈ Candle Close Approaching',
          block.sub || 'Prepare for candle close',
          icon
        );
      } else {
        showNotification(
          `▶ ${block.title}`,
          block.sub ? block.sub.slice(0, 80) : `Starting now · ${block.duration || ''}`,
          icon
        );
      }
      // Re-schedule for next day after midnight blocks fire
    }, msUntil);

    _notifTimers.push(id);

    // Also send a 2-minute warning for non-prep trade blocks
    if (!block.prep && block.type === 't-trade' && msUntil > 2 * 60 * 1000) {
      const warnId = setTimeout(() => {
        showNotification(
          `⚡ Trade Check in 2 mins`,
          `${block.title} starts at ${fmt12(block.time)}`,
          '/Izy-Schedule-v2/icons/icon-192.png'
        );
      }, msUntil - 2 * 60 * 1000);
      _notifTimers.push(warnId);
    }
  });

  console.log(`[IZ] Scheduled ${_notifTimers.length} notifications for today`);
}

function showNotification(title, body, icon) {
  if (Notification.permission !== 'granted') return;
  // Use service worker notification if available (works when app is in background)
  if ('serviceWorker' in navigator && navigator.serviceWorker.controller) {
    navigator.serviceWorker.ready.then(reg => {
      reg.showNotification(title, {
        body,
        icon,
        badge: icon,
        vibrate: [200, 100, 200],
        tag: 'iz-block',
        renotify: true,
      });
    });
  } else {
    // Fallback to direct notification (app must be open/focused)
    new Notification(title, { body, icon });
  }
}

async function requestNotificationPermission() {
  if (!('Notification' in window)) {
    showToast('Notifications not supported in this browser');
    return;
  }

  if (Notification.permission === 'granted') {
    setNotificationsEnabled(true);
    scheduleNotifications();
    syncNotifButton();
    showToast('Notifications enabled ✓');
    return;
  }

  if (Notification.permission === 'denied') {
    showToast('Notifications blocked — enable in browser settings');
    return;
  }

  const result = await Notification.requestPermission();
  if (result === 'granted') {
    setNotificationsEnabled(true);
    scheduleNotifications();
    syncNotifButton();
    showToast('Notifications enabled ✓');
  } else {
    showToast('Notification permission denied');
  }
}

function toggleNotifications() {
  if (notificationsEnabled()) {
    setNotificationsEnabled(false);
    cancelAllNotifications();
    syncNotifButton();
    showToast('Notifications disabled');
  } else {
    requestNotificationPermission();
  }
}

function syncNotifButton() {
  const btn = document.getElementById('notifBtn');
  if (!btn) return;
  const on = notificationsEnabled() && Notification.permission === 'granted';
  btn.textContent = on ? '🔔 Notifs On' : '🔕 Notifs Off';
  btn.classList.toggle('btn-primary', on);
}

// Re-schedule every hour as a safety net (handles midnight rollover)
setInterval(() => scheduleNotifications(), 60 * 60 * 1000);

// ─── PWA: Install prompt ───
let _installPrompt = null;

window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  _installPrompt = e;
  // Show install button if you have one, e.g.:
  const btn = document.getElementById('installBtn');
  if (btn) btn.style.display = 'inline-flex';
});

window.addEventListener('appinstalled', () => {
  _installPrompt = null;
  const btn = document.getElementById('installBtn');
  if (btn) btn.style.display = 'none';
  console.log('[IZ] App installed');
});

function triggerInstallPrompt() {
  if (_installPrompt) {
    _installPrompt.prompt();
    _installPrompt.userChoice.then(choice => {
      _installPrompt = null;
    });
  }
}

// ─── PWA: Register Service Worker ───
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js', { scope: './', updateViaCache: 'none' })
      .then(reg => {
        console.log('[IZ] SW registered:', reg.scope);
        // Force the SW to check for an updated version on every page load
        reg.update();
        // When a new SW is waiting, skip waiting and take over immediately
        reg.addEventListener('updatefound', () => {
          const newWorker = reg.installing;
          if (!newWorker) return;
          newWorker.addEventListener('statechange', () => {
            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
              // New version is ready — tell it to activate now
              newWorker.postMessage({ type: 'SKIP_WAITING' });
            }
          });
        });
        // Init notifications after SW is ready
        if (notificationsEnabled() && Notification.permission === 'granted') {
          scheduleNotifications();
        }
      })
      .catch(err => console.warn('[IZ] SW registration failed:', err));
  });

  // When the SW activates a new version, reload the page to load fresh assets
  let refreshing = false;
  navigator.serviceWorker.addEventListener('controllerchange', () => {
    if (!refreshing) {
      refreshing = true;
      window.location.reload();
    }
  });
}


// Init notif button state and version display on load
window.addEventListener('DOMContentLoaded', () => {
  syncNotifButton();
  const v = document.getElementById('footerVersion');
  if (v) v.textContent = `IZ v${APP_VERSION}`;
});

// ─────────────────────────────────────────────────────
// AUTH + CLOUD SYNC
// ─────────────────────────────────────────────────────

// ── Sync dot state ───────────────────────────────────
function setSyncState(state) {
  const dot = document.getElementById('syncDot');
  if (!dot) return;
  dot.className = 'sync-dot' + (state === 'syncing' ? ' syncing' : state === 'error' ? ' error' : state === 'offline' ? ' offline' : '');
  dot.title = { syncing:'Syncing…', error:'Sync error', offline:'Offline', ok:'Synced' }[state] || '';
}

// ── User pill ─────────────────────────────────────────
function renderUserPill(user) {
  const el = document.getElementById('userPill');
  if (!el) return;
  if (user) {
    el.innerHTML = `<div class="user-pill">
      <span class="sync-dot" id="syncDot" title="Synced"></span>
      <span class="user-email" title="${escHtml(user.email)}">${escHtml(user.email)}</span>
      <button class="user-action-btn" id="signOutBtn">Sign Out</button>
    </div>`;
    if (!navigator.onLine) setSyncState('offline');
  } else {
    el.innerHTML = `<button class="signin-btn" id="signInBtn">Sign In</button>`;
  }
}

// Event delegation on userPill — survives innerHTML re-renders
document.getElementById('userPill').addEventListener('click', e => {
  if (e.target.id === 'signOutBtn') doSignOut();
  if (e.target.id === 'signInBtn')  openAuth();
});

// ── Auth modal ────────────────────────────────────────
function openAuth(panel) {
  showAuthPanel(panel || 'in');
  document.getElementById('authOverlay').classList.add('open');
  setTimeout(() => {
    const el = document.getElementById('inEmail');
    if (el) el.focus();
  }, 80);
}

function closeAuth() {
  document.getElementById('authOverlay').classList.remove('open');
  clearAuthMsgs();
}

document.getElementById('authOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeAuth();
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.getElementById('authOverlay').classList.contains('open')) {
    closeAuth();
  }
});

function showAuthPanel(panel) {
  document.getElementById('panelIn').style.display    = panel === 'in'    ? '' : 'none';
  document.getElementById('panelUp').style.display    = panel === 'up'    ? '' : 'none';
  document.getElementById('panelReset').style.display = panel === 'reset' ? '' : 'none';
  const tabIn = document.getElementById('tabIn');
  const tabUp = document.getElementById('tabUp');
  if (tabIn) tabIn.classList.toggle('active', panel === 'in');
  if (tabUp) tabUp.classList.toggle('active', panel === 'up');
  clearAuthMsgs();
}

function clearAuthMsgs() {
  ['inErr','upErr','upOk','resetErr','resetOk'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.textContent = ''; el.classList.remove('show'); }
  });
}

function showMsg(id, text, type) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = 'auth-msg ' + type + ' show';
}

async function doSignIn() {
  if (!_sb) return;
  const email = document.getElementById('inEmail').value.trim();
  const pass  = document.getElementById('inPass').value;
  if (!email || !pass) { showMsg('inErr','Please enter your email and password.','error'); return; }
  const btn = document.getElementById('inBtn');
  btn.disabled = true; btn.textContent = 'Signing in…';
  const { error } = await _sb.auth.signInWithPassword({ email, password: pass });
  btn.disabled = false; btn.textContent = 'Sign In';
  if (error) { showMsg('inErr', error.message, 'error'); return; }
  closeAuth();
}

async function doSignUp() {
  if (!_sb) return;
  const email = document.getElementById('upEmail').value.trim();
  const pass  = document.getElementById('upPass').value;
  if (!email || !pass) { showMsg('upErr','Please enter your email and password.','error'); return; }
  if (pass.length < 6) { showMsg('upErr','Password must be at least 6 characters.','error'); return; }
  const btn = document.getElementById('upBtn');
  btn.disabled = true; btn.textContent = 'Creating…';
  const { error } = await _sb.auth.signUp({ email, password: pass });
  btn.disabled = false; btn.textContent = 'Create Account';
  if (error) { showMsg('upErr', error.message, 'error'); return; }
  showMsg('upOk', 'Account created — check your email to confirm, then sign in.', 'ok');
}

async function doReset() {
  if (!_sb) return;
  const email = document.getElementById('resetEmail').value.trim();
  if (!email) { showMsg('resetErr','Please enter your email.','error'); return; }
  const { error } = await _sb.auth.resetPasswordForEmail(email);
  if (error) { showMsg('resetErr', error.message, 'error'); return; }
  showMsg('resetOk', 'Reset email sent — check your inbox.', 'ok');
}

async function doSignOut() {
  if (!_sb) return;
  _sbUser = null;
  renderUserPill(null);
  await _sb.auth.signOut();
}

// ── Online / offline ──────────────────────────────────
window.addEventListener('online', () => {
  if (_sbUser) {
    setSyncState('syncing');
    pushToCloud();
  }
});
window.addEventListener('offline', () => setSyncState('offline'));

// ── Auth state changes ────────────────────────────────
if (_sb) {
  _sb.auth.onAuthStateChange(async (event, session) => {
    _sbUser = session?.user ?? null;
    renderUserPill(_sbUser);
    if (_sbUser) {
      await pullFromCloud();
    }
  });

  // Restore session on page load
  _sb.auth.getSession().then(({ data: { session } }) => {
    _sbUser = session?.user ?? null;
    renderUserPill(_sbUser);
    if (_sbUser) pullFromCloud();
  });
}
</script>
</body>
</html>
