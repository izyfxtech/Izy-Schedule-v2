<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IZ — Weekly Schedule</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%230a0806'/><text x='16' y='23' font-family='system-ui,sans-serif' font-size='16' font-weight='700' text-anchor='middle' fill='%23e8a020'>IZ</text></svg>">
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#090704">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="IZ">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<style>
/* ═══════════════════════════════════════════════════════
   AXIS 1: BRIGHTNESS — controls surfaces, text, borders
   Default (no attribute) = Espresso warm dark
   ═══════════════════════════════════════════════════════ */
:root {
  --bg:       #0a0806;
  --surface:  #120f0a;
  --surface2: #1a1510;
  --border:   #241c12;
  --border2:  #2e2418;
  --text:     #e2d4be;
  --muted:    #826e56;
  --dim:      #4c3e2c;
  --weekend-color:  #907060;
  --weekend-active: #c09870;
  --danger:   #d95f4b;

  /* ── AXIS 2: ACCENT — default Espresso amber ── */
  --trade:        #e8a020;
  --trade-bg:     rgba(232,160,32,0.08);
  --trade-border: rgba(232,160,32,0.32);
  --trade-title:  #f4c455;
  --current-shadow: 0 0 0 1px rgba(232,160,32,0.42), 0 2px 24px rgba(232,160,32,0.1);
  --prep-bg:   rgba(52,38,10,0.4);
  --prep-bd:   rgba(232,160,32,0.22);
}

/* ── BRIGHTNESS: Dark (neutral) ── */
[data-brightness="dark"] {
  --bg:       #0a0a0a;
  --surface:  #141414;
  --surface2: #1e1e1e;
  --border:   #2a2a2a;
  --border2:  #363636;
  --text:     #f0f0f0;
  --muted:    #707070;
  --dim:      #404040;
  --weekend-color:  #585858;
  --weekend-active: #909090;
  --danger:   #e04040;
}

/* ── BRIGHTNESS: Light ── */
[data-brightness="light"] {
  --bg:       #ffffff;
  --surface:  #f4f4f5;
  --surface2: #e8e8ec;
  --border:   #d4d4d8;
  --border2:  #c0c0c8;
  --text:     #0e0e12;
  --muted:    #6c6c80;
  --dim:      #a8a8b8;
  --weekend-color:  #8888a0;
  --weekend-active: #4040a0;
  --danger:   #cc2222;
}

/* ── BRIGHTNESS: Warm (Parchment) ── */
[data-brightness="warm"] {
  --bg:       #f9f3e5;
  --surface:  #f1e9d4;
  --surface2: #e8dfca;
  --border:   #d4c8aa;
  --border2:  #c6b898;
  --text:     #1c1408;
  --muted:    #7c6a4e;
  --dim:      #b0a080;
  --weekend-color:  #9e8060;
  --weekend-active: #6a4828;
  --danger:   #c02828;
}

/* ═══════════════════════════════════════════════════════
   AXIS 2: ACCENT — controls trade/highlight colour
   Default = Espresso amber (set in :root above)
   ═══════════════════════════════════════════════════════ */

/* ── ACCENT: Terminal ── */
[data-accent="terminal"] {
  --trade:        #10d864;
  --trade-bg:     rgba(16,216,100,0.07);
  --trade-border: rgba(16,216,100,0.30);
  --trade-title:  #48f088;
  --current-shadow: 0 0 0 1px rgba(16,216,100,0.42), 0 2px 24px rgba(16,216,100,0.1);
  --prep-bg: rgba(4,26,12,0.55);
  --prep-bd: rgba(16,216,100,0.20);
}

/* ── ACCENT: Slate ── */
[data-accent="slate"] {
  --trade:        #4a80f8;
  --trade-bg:     rgba(74,128,248,0.08);
  --trade-border: rgba(74,128,248,0.34);
  --trade-title:  #80a8ff;
  --current-shadow: 0 0 0 1px rgba(74,128,248,0.46), 0 2px 24px rgba(74,128,248,0.12);
  --prep-bg: rgba(14,16,58,0.5);
  --prep-bd: rgba(74,128,248,0.20);
}

/* ── ACCENT: Midnight ── */
[data-accent="midnight"] {
  --trade:        #8868f8;
  --trade-bg:     rgba(136,104,248,0.08);
  --trade-border: rgba(136,104,248,0.33);
  --trade-title:  #a890ff;
  --current-shadow: 0 0 0 1px rgba(136,104,248,0.44), 0 2px 24px rgba(136,104,248,0.12);
  --prep-bg: rgba(24,20,60,0.5);
  --prep-bd: rgba(136,104,248,0.22);
}

/* ── ACCENT: Crimson ── */
[data-accent="crimson"] {
  --trade:        #e8386a;
  --trade-bg:     rgba(232,56,106,0.08);
  --trade-border: rgba(232,56,106,0.32);
  --trade-title:  #ff6888;
  --current-shadow: 0 0 0 1px rgba(232,56,106,0.44), 0 2px 24px rgba(232,56,106,0.1);
  --prep-bg: rgba(50,10,28,0.55);
  --prep-bd: rgba(232,56,106,0.20);
}

/* ── ACCENT: Arctic ── */
[data-accent="arctic"] {
  --trade:        #18c8f0;
  --trade-bg:     rgba(24,200,240,0.07);
  --trade-border: rgba(24,200,240,0.30);
  --trade-title:  #58e0ff;
  --current-shadow: 0 0 0 1px rgba(24,200,240,0.40), 0 2px 24px rgba(24,200,240,0.1);
  --prep-bg: rgba(8,38,58,0.55);
  --prep-bd: rgba(24,200,240,0.20);
}

/* ── ACCENT: Dusk ── */
[data-accent="dusk"] {
  --trade:        #c060e8;
  --trade-bg:     rgba(192,96,232,0.08);
  --trade-border: rgba(192,96,232,0.32);
  --trade-title:  #e090ff;
  --current-shadow: 0 0 0 1px rgba(192,96,232,0.42), 0 2px 24px rgba(192,96,232,0.1);
  --prep-bg: rgba(40,16,64,0.55);
  --prep-bd: rgba(192,96,232,0.22);
}

/* ── Light/warm brightness overrides for accent prep-bg opacity ──
   Both data-* attributes sit on <html>, so compound selector (no space) is correct. ── */
[data-brightness="light"][data-accent] { --prep-bg: var(--trade-bg); }
[data-brightness="warm"][data-accent]  { --prep-bg: var(--trade-bg); }
html, body, .header-wrap, .header, .now-panel, .day-tab, .schedule-outer, .schedule-wrapper, .footer-wrap,
.toolbar, .btn, .block-content, .prep-bar, .modal,
.reset-box, .toast, .footer, .form-group input,
.form-group textarea, .form-group select {
  transition: background-color 0.3s ease, border-color 0.3s ease, color 0.25s ease, box-shadow 0.3s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  min-height: 100vh;
  padding-bottom: 80px;
  user-select: none;
  -webkit-user-select: none;
}

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

/* ── HEADER ── */
.header-wrap {
  border-bottom: 1px solid var(--border);
}
.header {
  padding: 28px 32px 20px;
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
}
.header h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 52px;
  letter-spacing: 3px;
  line-height: 1;
}
.header-sub {
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 5px;
}
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
}
.clock-display {
  font-family: 'DM Mono', 'Courier New', monospace;
  font-size: 22px;
  font-weight: 500;
  color: var(--text);
  letter-spacing: 1px;
  line-height: 1;
}
.clock-date {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-top: 2px;
  text-align: right;
}
.badges { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.badge {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  padding: 3px 9px;
  border-radius: 4px;
  letter-spacing: 1px;
  text-transform: uppercase;
  border: 1px solid;
}
.badge-green  { color: var(--trade); border-color: var(--trade-border); background: var(--trade-bg); }
.badge-yellow { color: var(--muted); border-color: var(--border2); background: var(--surface); }

/* ── NOW BANNER ── */
.now-banner { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
.now-inner {
  display: flex;
  border: 1px solid var(--border2);
  border-top: none;
  border-radius: 0 0 8px 8px;
  overflow: hidden;
}
.now-panel { flex: 1; padding: 10px 16px; background: var(--surface); }
.now-panel:first-child { border-right: 1px solid var(--border); }
.now-panel.is-linked {
  cursor: pointer;
  transition: background 0.15s;
}
.now-panel.is-linked:hover { background: var(--surface2); }
.now-panel.is-linked .now-panel-label::after { content: ' ↗'; opacity: 0.5; }
.now-panel-label {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--dim);
  margin-bottom: 3px;
}
.now-panel-title { font-size: 13px; font-weight: 600; line-height: 1.2; }
.now-panel-sub { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); margin-top: 2px; }
.glow-dot {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--trade);
  box-shadow: 0 0 8px var(--trade);
  margin-right: 6px;
  vertical-align: middle;
  animation: glow 2s ease-in-out infinite;
}
@keyframes blockFlash {
  0%   { filter: brightness(1); }
  25%  { filter: brightness(1.9); }
  60%  { filter: brightness(1.5); }
  100% { filter: brightness(1); }
}
.block-flash { animation: blockFlash 0.8s ease-out; }
@keyframes glow { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── DAY TABS ── */
.day-tabs {
  max-width: 1100px;
  margin: 0 auto;
  padding: 20px 32px 0;
  display: flex;
  gap: 4px;
}
.day-tab {
  flex: 1;
  padding: 10px 6px;
  border-radius: 8px 8px 0 0;
  border: 1px solid var(--border);
  border-bottom: none;
  background: var(--surface);
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  text-align: center;
  transition: all 0.15s;
  position: relative;
  top: 1px;
}
.day-tab:hover { color: var(--text); background: var(--surface2); }
.day-tab.active {
  background: var(--bg);
  color: var(--text);
  border-color: var(--border2);
  border-bottom-color: var(--bg);
  font-weight: 600;
}
.day-tab.weekend { color: var(--weekend-color); }
.day-tab.weekend.active { color: var(--weekend-active); }
.today-dot {
  display: inline-block;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--trade);
  margin-left: 4px;
  vertical-align: middle;
  position: relative;
  top: -1px;
}

/* ── SCHEDULE ── */
.schedule-outer {
  border-top: 1px solid var(--border2);
}
.schedule-wrapper {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ── TOOLBAR ── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0 12px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 10px;
}
.toolbar-left { display: flex; align-items: baseline; gap: 8px; }
.toolbar-day { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 2px; }
.toolbar-type { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: 1.5px; text-transform: uppercase; }
.toolbar-right { display: flex; gap: 8px; flex-wrap: wrap; }
.toolbar-right .btn { flex-shrink: 0; }

/* ── BUTTONS ── */
.btn {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 7px 14px;
  border-radius: 6px;
  border: 1px solid var(--border2);
  background: var(--surface);
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
}
.btn:hover { color: var(--text); background: var(--surface2); }
.btn-primary { background: var(--trade-bg); color: var(--trade); border-color: var(--trade-border); }
.btn-primary:hover { background: var(--trade-border); }
.btn-add { background: var(--trade-bg); color: var(--trade); border-color: var(--trade-border); font-weight: 600; }
.btn-add:hover { background: var(--trade-border); color: var(--trade); }
.btn-danger { color: var(--danger); border-color: color-mix(in srgb, var(--danger) 35%, transparent); }
.btn-danger:hover { background: color-mix(in srgb, var(--danger) 10%, transparent); }

/* Fix G: Undo button — disabled when no action to undo, styled distinctly */
.btn-undo { color: var(--dim); border-color: var(--border); }
.btn-undo:not(:disabled):hover { color: var(--text); background: var(--surface2); }
.btn-undo:disabled { opacity: 0.35; cursor: not-allowed; }
.btn-undo.has-undo { color: var(--trade); border-color: var(--trade-border); background: var(--trade-bg); }
.btn-undo.has-undo:hover { background: var(--trade-border); }

/* Fix H: toolbar visual separators between logical groups */
.toolbar-sep {
  width: 1px; background: var(--border2); align-self: stretch;
  margin: 0 2px; flex-shrink: 0;
}

/* ── LEGEND ── */
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 18px;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.legend-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

/* ── SCHEDULE ── */
.schedule { position: relative; }

.schedule::before {
  content: '';
  position: absolute;
  left: 62px; top: 0; bottom: 0;
  width: 1px;
  background: var(--border);
}

.block-row { display: flex; margin-bottom: 3px; position: relative; }
.time-col {
  width: 62px;
  flex-shrink: 0;
  padding-right: 14px;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding-top: 11px;
}
.time-label { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text); white-space: nowrap; }
.block-content {
  flex: 1;
  margin-left: 14px;
  border-radius: 8px;
  border-left: 3px solid;
  padding: 10px 90px 10px 13px;
  position: relative;
  cursor: pointer;
  transition: filter 0.15s;
  user-select: none;
}
.block-content:hover { filter: brightness(1.2); }
.block-content.current-block {
  box-shadow: var(--current-shadow);
  filter: brightness(1.15);
}
/* Block titles — all identical */
.block-title { font-size: 13px; font-weight: 600; line-height: 1.3; display: block; color: var(--text); }

/* Subtitles — layout + color merged */
.block-sub { font-size: 11px; margin-top: 3px; line-height: 1.4; color: var(--muted); }
.block-duration {
  position: absolute; top: 10px; right: 36px;
  font-family: 'DM Mono', monospace; font-size: 10px;
  color: var(--muted); opacity: 0.6;
}
.block-edit-btn {
  position: absolute; top: 50%; right: 10px; transform: translateY(-50%);
  background: none; border: none; color: var(--muted); cursor: pointer;
  opacity: 0; transition: opacity 0.15s; font-size: 14px; padding: 4px;
}
.block-content:hover .block-edit-btn { opacity: 0.7; }
.block-content:hover .block-edit-btn:hover { opacity: 1; }
.now-tag {
  display: block; font-family: 'DM Mono', monospace; font-size: 9px;
  letter-spacing: 1px; text-transform: uppercase; color: var(--trade);
  margin-bottom: 4px; animation: glow 2s ease-in-out infinite;
}

/* ── PREP ROW ── */
.prep-row { display: flex; margin-bottom: 3px; }
.prep-spacer {
  width: 62px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: flex-end; padding-right: 14px;
}
.prep-time { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); opacity: 0.7; }
.prep-bar {
  flex: 1; margin-left: 14px; border-radius: 5px; padding: 5px 12px;
  background: var(--prep-bg); border-left: 2px solid var(--prep-bd);
  font-size: 10px; color: var(--muted); opacity: 0.75; font-family: 'DM Mono', monospace;
  letter-spacing: 0.5px; display: flex; align-items: center; gap: 7px;
  cursor: pointer; transition: opacity 0.15s;
}
.prep-bar:hover { opacity: 1; }
.prep-pulse { font-size: 7px; animation: pulse 2.5s ease-in-out infinite; color: var(--trade); }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.25} }

.hour-sep { height: 1px; background: var(--border); margin: 6px 0 6px 76px; opacity: 0.35; }

/* ── BLOCK COLORS — all identical at base; per-block colour applied via inline style ── */
/* Category classes kept for data compatibility but no longer drive visual style */
.t-trade, .t-sleep, .t-meal, .t-move,
.t-life,  .t-admin, .t-study, .t-free {
  background: var(--surface);
  border-color: var(--border2);
}

/* ── BLOCK COLOR PICKER ── */
.color-picker-row {
  margin-bottom: 15px;
}
.color-picker-row label {
  display: block; font-family: 'DM Mono', monospace; font-size: 10px;
  text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 8px;
}
.color-swatches {
  display: flex; flex-wrap: wrap; gap: 7px; align-items: center;
}
.color-swatch {
  width: 22px; height: 22px; border-radius: 50%;
  border: 2px solid transparent; cursor: pointer;
  transition: transform 0.12s, border-color 0.12s;
  flex-shrink: 0;
}
.color-swatch:hover { transform: scale(1.2); }
.color-swatch.selected { border-color: var(--text); transform: scale(1.15); }
.color-swatch-none {
  background: var(--surface); border: 1px dashed var(--border2);
  color: var(--muted); font-size: 11px; display: flex;
  align-items: center; justify-content: center; border-radius: 50%;
  width: 22px; height: 22px; cursor: pointer; flex-shrink: 0;
  transition: border-color 0.12s;
}
.color-swatch-none:hover, .color-swatch-none.selected { border-color: var(--muted); }
.color-custom-input {
  width: 28px; height: 28px; border-radius: 6px; border: 1px solid var(--border2);
  cursor: pointer; background: none; padding: 0; overflow: hidden;
  flex-shrink: 0;
}
.color-custom-input::-webkit-color-swatch-wrapper { padding: 0; }
.color-custom-input::-webkit-color-swatch { border: none; border-radius: 4px; }
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.72); z-index: 100;
  align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--surface2); border: 1px solid var(--border2); border-radius: 12px;
  padding: 28px; width: 460px; max-width: 95vw; max-height: 90vh; overflow-y: auto;
  animation: slideUp 0.2s ease;
}
@keyframes slideUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }

/* Fix K: modal header with title + close button */
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 22px;
}
.modal-header h2 {
  font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px;
  color: var(--text); margin: 0;
}
.modal-close-btn {
  background: none; border: none; color: var(--muted); cursor: pointer;
  font-size: 18px; line-height: 1; padding: 4px 6px; border-radius: 4px;
  transition: color 0.15s, background 0.15s; flex-shrink: 0;
}
.modal-close-btn:hover { color: var(--text); background: var(--border2); }

.form-group { margin-bottom: 15px; }
.form-group label {
  display: block; font-family: 'DM Mono', monospace; font-size: 10px;
  text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 6px;
}
.form-group input, .form-group textarea, .form-group select {
  width: 100%; background: var(--surface); border: 1px solid var(--border2);
  border-radius: 6px; color: var(--text); font-family: 'DM Sans', sans-serif;
  font-size: 13px; padding: 9px 12px; outline: none; transition: border-color 0.15s;
  user-select: text;
  -webkit-user-select: text;
}
.form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--trade); }
.form-group select:disabled { opacity: 0.35; cursor: not-allowed; }
.form-group textarea { resize: vertical; min-height: 60px; }
.form-group select option { background: var(--surface2); }
.form-row { display: flex; gap: 12px; }
.form-row .form-group { flex: 1; }

/* Fix B: prep check row — appears ABOVE category */
.prep-check-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.prep-check-row input[type=checkbox] { width: 14px; height: 14px; accent-color: var(--trade); cursor: pointer; flex-shrink: 0; }
.prep-check-row label { font-size: 12px; color: var(--muted); cursor: pointer; line-height: 1.4; }

/* Fix F+E: modal footer restructured — overlap warning + delete confirm + actions all live here */
.modal-footer {
  margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--border);
}
/* Normal action row: Cancel on left, Delete+Save on right */
.modal-footer-actions {
  display: flex; justify-content: space-between; align-items: center;
}
.modal-footer-right { display: flex; gap: 8px; }

/* Fix F: overlap warning moved into footer zone — buttons always at bottom */
.overlap-warning {
  display: none; margin-bottom: 14px;
  padding: 10px 13px; border-radius: 6px;
  background: var(--trade-bg); border: 1px solid var(--trade-border);
  font-size: 12px; color: var(--muted); font-family: 'DM Mono', monospace;
  letter-spacing: 0.3px; line-height: 1.6;
}
.overlap-warning.show { display: block; }
.overlap-warning strong { color: var(--text); display: block; margin-bottom: 5px; }
.overlap-warning-btns { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }

/* Day placement picker — shown for ambiguous overnight times */
.day-picker-banner {
  display: none;
  padding: 11px 14px; margin-bottom: 14px;
  border-radius: 6px; border: 1px solid var(--trade-border);
  background: var(--trade-bg);
  font-size: 12px; color: var(--muted); font-family: 'DM Mono', monospace;
}
.day-picker-banner.show { display: block; }
.day-picker-msg { display: block; color: var(--text); margin-bottom: 10px; letter-spacing: 0.3px; line-height: 1.5; }
.day-picker-btns { display: flex; gap: 8px; justify-content: flex-end; flex-wrap: wrap; }

/* Fix E: delete confirm banner replaces footer actions in-place */
.delete-confirm-banner {
  display: none;
  padding: 11px 14px; margin-bottom: 14px;
  border-radius: 6px;
  border: 1px solid color-mix(in srgb, var(--danger) 40%, transparent);
  background: var(--surface2);
  font-size: 12px; color: var(--muted); font-family: 'DM Mono', monospace;
}
.delete-confirm-banner.show { display: block; }
.delete-confirm-msg { display: block; color: var(--danger); margin-bottom: 10px; letter-spacing: 0.5px; }
.delete-confirm-btns { display: flex; gap: 8px; justify-content: flex-end; }

/* Inline modal error */
.modal-error {
  display: none; margin-bottom: 14px;
  padding: 9px 12px; border-radius: 6px;
  background: color-mix(in srgb, var(--danger) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--danger) 35%, transparent);
  font-size: 12px; color: var(--danger); font-family: 'DM Mono', monospace;
  letter-spacing: 0.5px; line-height: 1.5;
}
.modal-error.show { display: block; }

/* ── RESET CONFIRM ── */
.reset-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.75); z-index: 200;
  align-items: center; justify-content: center;
}
.reset-overlay.open { display: flex; }
.reset-box {
  background: var(--surface2);
  border: 1px solid color-mix(in srgb, var(--danger) 40%, transparent);
  border-radius: 12px; padding: 28px; max-width: 380px; width: 90%; text-align: center;
}
.reset-box h3 {
  font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 2px;
  color: var(--danger); margin-bottom: 12px;
}
.reset-box p { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 20px; }
.reset-box-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

/* ── TOAST — see Fix G block below for full definition ── */

/* ── FOOTER ── */
.footer-wrap {
  border-top: 1px solid var(--border);
  margin-top: 32px;
}
.footer {
  max-width: 1100px; margin: 0 auto;
  padding: 16px 32px;
}
.footer p {
  font-family: 'DM Mono', monospace; font-size: 10px; color: var(--dim);
  letter-spacing: 1px; line-height: 1.8; text-transform: uppercase;
}

/* ── BLEED-IN: continuation blocks from the previous day ── */
.bleed-in-block {
  border-left-style: dashed;
  opacity: 0.75;
  cursor: pointer;
}
.bleed-in-block:hover { opacity: 1; filter: brightness(1.15); }
.bleed-tag {
  display: block;
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
}

/* Fix C: floating add block button */
.fab-add {
  position: fixed;
  bottom: 28px;
  left: max(28px, calc(50% - 550px));
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--trade-bg); border: 1px solid var(--trade-border);
  color: var(--trade); font-size: 24px; font-weight: 300; line-height: 1;
  cursor: pointer; z-index: 50;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; box-shadow: 0 2px 16px rgba(0,0,0,0.3);
}
.fab-add:hover {
  background: var(--trade-border);
  box-shadow: 0 0 20px var(--trade-bg), 0 2px 16px rgba(0,0,0,0.3);
  transform: scale(1.08);
}

/* ── TABLET: 601–768px — toolbar wraps, separators hidden ── */
@media (max-width: 768px) and (min-width: 601px) {
  .toolbar-right { flex-wrap: wrap; gap: 6px; }
  .toolbar-sep { display: none; }
}

@media (max-width: 600px) {
  /* ── Header ── */
  .header { padding: 16px 16px 14px; gap: 10px; }
  .header h1 { font-size: 34px; }
  .header-sub { font-size: 10px; letter-spacing: 1px; }
  .header-right { align-items: flex-start; width: 100%; }
  .clock-display { font-size: 16px; }

  /* ── Theme picker — wrap onto two lines ── */
  .theme-picker { flex-wrap: wrap; gap: 5px 4px; margin-top: 2px; }
  .theme-picker-label { width: 100%; margin-bottom: 0; }
  .theme-picker-sep { display: none; }
  .brightness-toggle { margin-top: 2px; }

  /* ── Now banner ── */
  .now-banner { padding: 0 16px; }
  .now-inner { flex-direction: column; }
  .now-panel:first-child { border-right: none; border-bottom: 1px solid var(--border); }

  /* ── Day tabs ── */
  .day-tabs { padding: 12px 16px 0; gap: 3px; }
  .day-tab { font-size: 10px; padding: 8px 4px; letter-spacing: 0.5px; }

  /* ── Schedule ── */
  .schedule-wrapper { padding: 0 16px; }
  .block-content { padding-right: 38px; }
  .block-duration { display: none; }

  /* ── Toolbar ── */
  .toolbar { flex-direction: column; align-items: flex-start; padding: 12px 0 10px; }
  .toolbar-right {
    width: 100%;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 6px;
  }
  .toolbar-right .btn { font-size: 10px; padding: 6px 10px; }
  .toolbar-sep { display: none; }

  /* ── Always show edit affordance on touch ── */
  .block-edit-btn { opacity: 0.45 !important; }

  /* ── Toast — keep above FAB, full-width friendly ── */
  .toast {
    bottom: 84px; right: 16px; left: 16px;
    justify-content: space-between;
  }

  .fab-add { bottom: 20px; left: 20px; width: 44px; height: 44px; font-size: 22px; }

  /* ── Footer ── */
  .footer-wrap { margin-top: 16px; }
  .footer { padding: 12px 16px; }
  .footer p { font-size: 9px; }
}

/* Fix G: toast with inline undo button */
.toast {
  position: fixed; bottom: 28px; right: 28px;
  background: var(--surface2); border: 1px solid var(--border2); border-left: 3px solid var(--trade);
  border-radius: 8px; padding: 10px 14px;
  font-family: 'DM Mono', monospace; font-size: 11px; color: var(--trade);
  letter-spacing: 1px; text-transform: uppercase;
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.25s, transform 0.25s; z-index: 300;
  display: flex; align-items: center; gap: 10px;
  pointer-events: none;
}
.toast.show { opacity: 1; transform: translateY(0); pointer-events: auto; }
.toast-undo-btn {
  background: none; border: 1px solid var(--trade-border); border-radius: 4px;
  color: var(--trade); font-family: 'DM Mono', monospace; font-size: 10px;
  letter-spacing: 1px; text-transform: uppercase; cursor: pointer; padding: 3px 8px;
  transition: background 0.15s; flex-shrink: 0;
}
.toast-undo-btn:hover { background: var(--trade-bg); }

/* ── THEME PICKER ── */
.theme-picker {
  display: flex; align-items: center; gap: 5px; margin-top: 4px;
}
.theme-picker-label {
  font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--muted); margin-right: 2px; user-select: none;
}
.theme-swatch {
  width: 22px; height: 22px; border-radius: 50%; padding: 2px;
  background: var(--surface2); border: 1px solid var(--border2);
  cursor: pointer; transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.theme-swatch:hover { transform: scale(1.18); border-color: var(--muted); }
.theme-swatch.active {
  border: 2px solid var(--text); padding: 1px;
  box-shadow: 0 0 0 1px var(--trade);
}
.swatch-inner {
  width: 12px; height: 12px; border-radius: 50%; display: block; pointer-events: none;
}

/* ── BRIGHTNESS TOGGLE ── */
.theme-picker-sep {
  width: 1px; height: 22px; background: var(--border2); flex-shrink: 0; margin: 0 3px;
  align-self: center;
}
.brightness-toggle {
  display: flex; align-items: stretch;
  height: 22px;
  border: 1px solid var(--border2); border-radius: 6px;
  overflow: hidden; flex-shrink: 0;
}
.brightness-btn {
  font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.5px;
  padding: 0 8px; background: var(--surface); color: var(--muted);
  border: none; cursor: pointer; transition: background 0.15s, color 0.15s;
  white-space: nowrap; line-height: 1;
  display: flex; align-items: center;
}
.brightness-btn:not(:last-child) { border-right: 1px solid var(--border2); }
.brightness-btn:hover { background: var(--surface2); color: var(--text); }
.brightness-btn.active { background: var(--surface2); color: var(--text); }
/* ── AUTH MODAL ── */
.auth-overlay {
  display:none; position:fixed; inset:0; z-index:400;
  background:rgba(0,0,0,0.8); align-items:center; justify-content:center;
}
.auth-overlay.open { display:flex; }
.auth-box {
  background:var(--surface2); border:1px solid var(--border2); border-radius:14px;
  padding:32px; width:360px; max-width:95vw; animation:slideUp 0.2s ease;
}
.auth-logo {
  font-family:'Bebas Neue',sans-serif; font-size:40px; letter-spacing:5px;
  color:var(--trade); text-align:center; line-height:1; margin-bottom:4px;
}
.auth-sub {
  font-family:'DM Mono',monospace; font-size:9px; letter-spacing:2px;
  text-transform:uppercase; color:var(--muted); text-align:center; margin-bottom:26px;
}
.auth-tabs {
  display:flex; border:1px solid var(--border2); border-radius:6px;
  overflow:hidden; margin-bottom:20px;
}
.auth-tab {
  flex:1; padding:8px; font-family:'DM Mono',monospace; font-size:10px;
  letter-spacing:1px; text-transform:uppercase; background:var(--surface);
  color:var(--muted); border:none; cursor:pointer; transition:all 0.15s;
}
.auth-tab:first-child { border-right:1px solid var(--border2); }
.auth-tab.active { background:var(--surface2); color:var(--text); }
.auth-field { margin-bottom:13px; }
.auth-field label {
  display:block; font-family:'DM Mono',monospace; font-size:10px;
  text-transform:uppercase; letter-spacing:1.5px; color:var(--muted); margin-bottom:5px;
}
.auth-field input {
  width:100%; background:var(--surface); border:1px solid var(--border2);
  border-radius:6px; color:var(--text); font-family:'DM Sans',sans-serif;
  font-size:13px; padding:9px 12px; outline:none; transition:border-color 0.15s;
  user-select:text; -webkit-user-select:text;
}
.auth-field input:focus { border-color:var(--trade); }
.auth-btn {
  width:100%; padding:11px; margin-top:4px;
  background:var(--trade-bg); border:1px solid var(--trade-border); border-radius:6px;
  color:var(--trade); font-family:'DM Mono',monospace; font-size:11px;
  letter-spacing:1px; text-transform:uppercase; cursor:pointer; transition:background 0.15s;
}
.auth-btn:hover { background:var(--trade-border); }
.auth-btn:disabled { opacity:0.5; cursor:not-allowed; }
.auth-msg {
  display:none; margin-top:11px; padding:8px 11px; border-radius:5px;
  font-family:'DM Mono',monospace; font-size:11px; letter-spacing:0.3px; line-height:1.5;
  text-align:center;
}
.auth-msg.show { display:block; }
.auth-msg.error {
  background:color-mix(in srgb,var(--danger) 10%,transparent);
  border:1px solid color-mix(in srgb,var(--danger) 35%,transparent);
  color:var(--danger);
}
.auth-msg.ok {
  background:var(--trade-bg); border:1px solid var(--trade-border); color:var(--trade);
}
.auth-link {
  display:block; text-align:center; margin-top:13px;
  font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.5px;
  color:var(--muted);
}
.auth-link button {
  background:none; border:none; color:var(--trade); cursor:pointer;
  font:inherit; letter-spacing:inherit; padding:0; text-decoration:underline;
}

/* ── USER PILL ── */
.user-pill {
  display:flex; align-items:center; gap:7px; margin-top:4px;
  font-family:'DM Mono',monospace; font-size:10px; letter-spacing:1px;
  text-transform:uppercase; color:var(--muted);
}
.sync-dot {
  width:7px; height:7px; border-radius:50%; background:var(--trade); flex-shrink:0;
}
.sync-dot.offline  { background:var(--dim); }
.sync-dot.syncing  { animation:glow 1s ease-in-out infinite; }
.sync-dot.error    { background:var(--danger); }
.user-email {
  max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}
.user-action-btn {
  background:none; border:1px solid var(--border2); border-radius:4px;
  color:var(--dim); cursor:pointer; font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:1px; text-transform:uppercase;
  padding:2px 7px; transition:all 0.15s;
}
.user-action-btn:hover { color:var(--text); border-color:var(--muted); }
.signin-btn {
  background:var(--trade-bg); border:1px solid var(--trade-border); border-radius:5px;
  color:var(--trade); cursor:pointer; font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:1px; text-transform:uppercase;
  padding:4px 11px; transition:background 0.15s; margin-top:4px;
}
.signin-btn:hover { background:var(--trade-border); }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header-wrap">
<div class="header">
  <div>
    <h1>Weekly Schedule</h1>
    <div class="header-sub">Trading · SIWES · French · Network+ · Philosophy</div>
  </div>
  <div class="header-right">
    <div class="clock-display" id="clockTime">--:--:-- --</div>
    <div class="clock-date" id="clockDate">---</div>
    <div class="badges">
      <span class="badge badge-green">3–5× Daily Trade Checks</span>
      <span class="badge badge-yellow">Click any block to edit</span>
    </div>
    <div id="userPill"><button class="signin-btn" id="signInBtn">Sign In</button></div>
    <div class="theme-picker" id="themePicker">
      <span class="theme-picker-label">Accent</span>
      <button class="theme-swatch" data-accent="espresso" title="Espresso" onclick="applyAccent('espresso')">
        <span class="swatch-inner" style="background:#e8a020"></span>
      </button>
      <button class="theme-swatch" data-accent="terminal" title="Terminal" onclick="applyAccent('terminal')">
        <span class="swatch-inner" style="background:#10d864"></span>
      </button>
      <button class="theme-swatch" data-accent="slate" title="Slate" onclick="applyAccent('slate')">
        <span class="swatch-inner" style="background:#4a80f8"></span>
      </button>
      <button class="theme-swatch" data-accent="midnight" title="Midnight" onclick="applyAccent('midnight')">
        <span class="swatch-inner" style="background:#8868f8"></span>
      </button>
      <button class="theme-swatch" data-accent="crimson" title="Crimson" onclick="applyAccent('crimson')">
        <span class="swatch-inner" style="background:#e8386a"></span>
      </button>
      <button class="theme-swatch" data-accent="arctic" title="Arctic" onclick="applyAccent('arctic')">
        <span class="swatch-inner" style="background:#18c8f0"></span>
      </button>
      <button class="theme-swatch" data-accent="dusk" title="Dusk" onclick="applyAccent('dusk')">
        <span class="swatch-inner" style="background:#c060e8"></span>
      </button>
      <div class="theme-picker-sep"></div>
      <div class="brightness-toggle" id="brightnessToggle" title="Switch background brightness">
        <button class="brightness-btn" data-brightness="light" onclick="applyBrightness('light')">☀ Light</button>
        <button class="brightness-btn" data-brightness="espresso" onclick="applyBrightness('espresso')">◑ Warm</button>
        <button class="brightness-btn" data-brightness="warm" onclick="applyBrightness('warm')">☕ Paper</button>
        <button class="brightness-btn" data-brightness="dark" onclick="applyBrightness('dark')">◗ Dark</button>
      </div>
    </div>
  </div>
</div>
</div>

<!-- NOW BANNER -->
<div class="now-banner" id="nowBanner" style="display:none">
  <div class="now-inner">
    <div class="now-panel">
      <div class="now-panel-label">▶ Now Active</div>
      <div class="now-panel-title" id="nowTitle" style="color:var(--trade)">—</div>
      <div class="now-panel-sub" id="nowSub">—</div>
    </div>
    <div class="now-panel">
      <div class="now-panel-label">⏭ Up Next</div>
      <div class="now-panel-title" id="nextTitle" style="color:var(--muted)">—</div>
      <div class="now-panel-sub" id="nextSub">—</div>
    </div>
  </div>
</div>

<!-- DAY TABS -->
<div class="day-tabs" id="dayTabs"></div>

<!-- SCHEDULE WRAPPER -->
<div class="schedule-outer">
<div class="schedule-wrapper">
  <div class="toolbar">
    <div class="toolbar-left">
      <span class="toolbar-day" id="toolbarDay">Monday</span>
      <span class="toolbar-type" id="toolbarType">· Weekday</span>
    </div>
    <div class="toolbar-right">
      <button class="btn btn-add" onclick="openModal(null)">+ Add Block</button>
      <button class="btn btn-undo" id="undoBtn" onclick="undoLastAction()" title="Undo last add, edit, delete or reset" disabled>Undo</button>
      <div class="toolbar-sep"></div>
      <button class="btn" onclick="exportSchedule()" title="Export schedule as JSON">Export</button>
      <button class="btn" id="importTriggerBtn" onclick="showImportConfirm()" title="Import a previously exported JSON">Import</button>
      <input type="file" id="importFile" accept=".json" style="display:none" onchange="importSchedule(event)">
      <button class="btn" onclick="saveSchedule()" title="All edits are auto-saved. Click to confirm.">Force Save</button>
      <div class="toolbar-sep"></div>
      <button class="btn" id="notifBtn" onclick="toggleNotifications()" title="Toggle block start notifications">🔕 Notifs Off</button>
      <div class="toolbar-sep"></div>
      <button class="btn" id="saveDefaultBtn" onclick="saveAsDefault()" title="Save current schedule as the default for this day">Save as Default</button>
      <button class="btn btn-danger" onclick="showResetConfirm()" title="Reset this day to its default template">Reset Day</button>
    </div>
  </div>

  <div class="schedule" id="scheduleBody"></div>

</div>
</div>

<!-- AUTH MODAL -->
<div class="auth-overlay" id="authOverlay">
  <div class="auth-box">
    <div class="auth-logo">IZ</div>
    <div class="auth-sub">Weekly Schedule</div>
    <div class="auth-tabs">
      <button class="auth-tab active" id="tabIn"  onclick="showAuthPanel('in')">Sign In</button>
      <button class="auth-tab"        id="tabUp"  onclick="showAuthPanel('up')">Sign Up</button>
    </div>

    <!-- Sign in -->
    <div id="panelIn">
      <div class="auth-field"><label>Email</label>
        <input type="email" id="inEmail" placeholder="you@example.com" autocomplete="email"/>
      </div>
      <div class="auth-field"><label>Password</label>
        <input type="password" id="inPass" placeholder="••••••••" autocomplete="current-password"
               onkeydown="if(event.key==='Enter')doSignIn()"/>
      </div>
      <button class="auth-btn" id="inBtn" onclick="doSignIn()">Sign In</button>
      <div class="auth-msg error" id="inErr"></div>
      <div class="auth-link"><button onclick="showAuthPanel('reset')">Forgot password?</button></div>
    </div>

    <!-- Sign up -->
    <div id="panelUp" style="display:none">
      <div class="auth-field"><label>Email</label>
        <input type="email" id="upEmail" placeholder="you@example.com" autocomplete="email"/>
      </div>
      <div class="auth-field"><label>Password</label>
        <input type="password" id="upPass" placeholder="At least 6 characters" autocomplete="new-password"
               onkeydown="if(event.key==='Enter')doSignUp()"/>
      </div>
      <button class="auth-btn" id="upBtn" onclick="doSignUp()">Create Account</button>
      <div class="auth-msg error" id="upErr"></div>
      <div class="auth-msg ok"    id="upOk"></div>
    </div>

    <!-- Password reset -->
    <div id="panelReset" style="display:none">
      <div class="auth-field"><label>Email</label>
        <input type="email" id="resetEmail" placeholder="you@example.com" autocomplete="email"
               onkeydown="if(event.key==='Enter')doReset()"/>
      </div>
      <button class="auth-btn" onclick="doReset()">Send Reset Email</button>
      <div class="auth-msg error" id="resetErr"></div>
      <div class="auth-msg ok"    id="resetOk"></div>
      <div class="auth-link"><button onclick="showAuthPanel('in')">← Back to sign in</button></div>
    </div>
  </div>
</div>

<!-- FOOTER -->
<div class="footer-wrap">
<div class="footer">
  <p>◈ Candle closes: Mon–Fri 6 AM · Tue–Thu also 11 AM, 3 PM, 7 PM, 11 PM &nbsp;·&nbsp; Market closes Fri 10 PM, reopens Sun 10 PM &nbsp;·&nbsp; Changes saved automatically</p>
  <p style="margin-top:6px;opacity:0.45" id="footerVersion"></p>
</div>
</div>

<!-- EDIT MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="handleOverlayClick(event)">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Edit Block</h2>
      <button class="modal-close-btn" onclick="closeModal()" title="Close (Esc)">✕</button>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Start Time</label>
        <input type="time" id="fTime" />
      </div>
      <div class="form-group">
        <label>Duration</label>
        <input type="text" id="fDuration" placeholder="e.g. 45m or 1h 30m" />
      </div>
    </div>
    <div class="form-group">
      <label>Title</label>
      <input type="text" id="fTitle" placeholder="Block title" />
    </div>
    <div class="form-group">
      <label>Description</label>
      <textarea id="fSub" placeholder="Optional details..."></textarea>
    </div>
    <!-- Prep checkbox BEFORE Category — it disables category, so it must precede it -->
    <div class="prep-check-row">
      <input type="checkbox" id="fIsPrep" onchange="clearModalError();" />
      <label for="fIsPrep">Show as candle prep alert (amber bar)</label>
    </div>
    <!-- Hidden type field — kept for data compatibility with existing blocks -->
    <input type="hidden" id="fType" value="t-free" />
    <!-- Per-block colour picker -->
    <div class="color-picker-row" id="colorPickerRow">
      <label>Block Colour</label>
      <div class="color-swatches" id="colorSwatches">
        <div class="color-swatch-none selected" id="swatchNone" title="No colour" onclick="selectSwatch(null)">—</div>
        <div class="color-swatch" style="background:#e8a020" data-color="#e8a020" title="Amber"       onclick="selectSwatch('#e8a020')"></div>
        <div class="color-swatch" style="background:#e85020" data-color="#e85020" title="Orange-red"  onclick="selectSwatch('#e85020')"></div>
        <div class="color-swatch" style="background:#d94060" data-color="#d94060" title="Red"         onclick="selectSwatch('#d94060')"></div>
        <div class="color-swatch" style="background:#b040d0" data-color="#b040d0" title="Purple"      onclick="selectSwatch('#b040d0')"></div>
        <div class="color-swatch" style="background:#5588f0" data-color="#5588f0" title="Blue"        onclick="selectSwatch('#5588f0')"></div>
        <div class="color-swatch" style="background:#20a8d8" data-color="#20a8d8" title="Cyan"        onclick="selectSwatch('#20a8d8')"></div>
        <div class="color-swatch" style="background:#20c890" data-color="#20c890" title="Teal"        onclick="selectSwatch('#20c890')"></div>
        <div class="color-swatch" style="background:#40b840" data-color="#40b840" title="Green"       onclick="selectSwatch('#40b840')"></div>
        <div class="color-swatch" style="background:#a0c830" data-color="#a0c830" title="Lime"        onclick="selectSwatch('#a0c830')"></div>
        <div class="color-swatch" style="background:#708090" data-color="#708090" title="Slate grey"  onclick="selectSwatch('#708090')"></div>
        <div class="color-swatch" style="background:#c0a890" data-color="#c0a890" title="Sand"        onclick="selectSwatch('#c0a890')"></div>
        <input type="color" class="color-custom-input" id="colorCustom" title="Custom colour" value="#e8a020" oninput="selectSwatch(this.value)" />
      </div>
    </div>
    <div class="modal-error" id="modalError"></div>
    <!-- Footer: overlap warning replaces action buttons when active -->
    <div class="modal-footer">
      <!-- Overlap warning lives in the footer so it appears where user attention already is -->
      <div class="overlap-warning" id="overlapWarning">
        <strong id="overlapMsg"></strong>
        <span id="overlapList"></span>
        <div class="overlap-warning-btns">
          <button class="btn" onclick="dismissOverlap()">← Go Back</button>
          <button class="btn btn-primary" onclick="saveBlockForce()">Save Anyway</button>
        </div>
      </div>
      <!-- Day placement picker — shown for ambiguous midnight times -->
      <div class="day-picker-banner" id="dayPickerBanner">
        <span class="day-picker-msg" id="dayPickerMsg"></span>
        <div class="day-picker-btns">
          <button class="btn" onclick="dismissDayPicker()">← Go Back</button>
          <button class="btn btn-primary" id="dayPickerThisDay" onclick="commitWithDay('this')"></button>
          <button class="btn btn-primary" id="dayPickerNextDay" onclick="commitWithDay('next')"></button>
        </div>
      </div>
      <!-- Delete confirm banner — shown in-place when delete is armed -->
      <div class="delete-confirm-banner" id="deleteConfirmBanner">
        <span class="delete-confirm-msg">Delete this block permanently?</span>
        <div class="delete-confirm-btns">
          <button class="btn" onclick="cancelDeleteArm()">Keep Block</button>
          <button class="btn btn-danger" onclick="deleteBlock()">Yes, Delete</button>
        </div>
      </div>
      <!-- Normal footer actions -->
      <div class="modal-footer-actions" id="footerActions">
        <button class="btn" onclick="closeModal()">Cancel</button>
        <div class="modal-footer-right">
          <button class="btn btn-danger" id="deleteBtn" onclick="armDelete()" style="display:none">Delete Block</button>
          <button class="btn btn-primary" id="saveBtn" onclick="saveBlock()">Save Block</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- IMPORT PRE-CONFIRM (warns BEFORE the file picker opens) -->
<div class="reset-overlay" id="importPreConfirm">
  <div class="reset-box">
    <h3>Import Schedule?</h3>
    <p>This will <strong>replace your entire schedule</strong> with data from a JSON file. Your current schedule will be lost unless you export it first.</p>
    <div class="reset-box-btns">
      <button class="btn" onclick="closeImportPreConfirm()">Cancel</button>
      <button class="btn btn-danger" onclick="proceedToFilePicker()">Choose File →</button>
    </div>
  </div>
</div>

<!-- IMPORT CONFIRM -->
<div class="reset-overlay" id="importOverlay">
  <div class="reset-box">
    <h3>Replace Schedule?</h3>
    <p>This will replace your entire schedule with the imported file. This cannot be undone.</p>
    <div class="reset-box-btns">
      <button class="btn" onclick="closeImportConfirm()">Cancel</button>
      <button class="btn btn-danger" onclick="confirmImport()">Replace Schedule</button>
    </div>
  </div>
</div>

<!-- RESET CONFIRM -->
<div class="reset-overlay" id="resetOverlay">
  <div class="reset-box">
    <h3>Reset Day?</h3>
    <p id="resetMsg">This will restore the default template for <strong id="resetDayName">this day</strong>. Your saved changes will be lost.</p>
    <div class="reset-box-btns">
      <button class="btn" onclick="closeResetConfirm()">Cancel</button>
      <button class="btn" id="clearDefaultBtn" onclick="clearUserDefault()" style="display:none" title="Remove custom default and revert to factory template">Clear Custom Default</button>
      <button class="btn btn-danger" onclick="confirmReset()">Reset to Default</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <span id="toastMsg"></span>
  <button class="toast-undo-btn" id="toastUndoBtn" onclick="undoLastAction()" style="display:none">Undo</button>
</div>

<!-- FLOATING ADD BUTTON -->
<button class="fab-add" onclick="openModal(null)" title="Add a new block">+</button>

<script>
// ─────────────────────────────────────────────────────
// TEMPLATES
// ─────────────────────────────────────────────────────
const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
const WEEKEND_IDS = [5, 6];
const STORAGE_KEY      = 'iz-weekly-schedule-v1';
const USER_DEFAULT_KEY = 'iz-user-defaults-v1';

// ─── Supabase ─────────────────────────────────────────
// Replace these two values with your own from:
// supabase.com → your project → Settings → API
const SUPABASE_URL  = 'https://jjbmyljbysdajqdexqcf.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpqYm15bGpieXNkYWpxZGV4cWNmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyMDI2ODIsImV4cCI6MjA4OTc3ODY4Mn0.fuz17JWQye3bXEF0PhvakKW9hf0ugsvIwAnb15-PCUE';
const _sb = (typeof supabase !== 'undefined')
  ? supabase.createClient(SUPABASE_URL, SUPABASE_ANON)
  : null;

let _sbUser   = null;   // currently signed-in user
let _pushTimer = null;  // debounce handle for cloud push

// Write weekData to localStorage, then debounce a cloud push
function cloudSave() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(weekData)); } catch(e) {}
  if (!_sbUser || !_sb) return;
  clearTimeout(_pushTimer);
  _pushTimer = setTimeout(pushToCloud, 600);
}

async function pushToCloud() {
  if (!_sbUser || !_sb) return;
  setSyncState('syncing');
  try {
    let accent = 'espresso', brightness = 'espresso';
    try { accent     = localStorage.getItem(ACCENT_KEY)     || 'espresso'; } catch(e) {}
    try { brightness = localStorage.getItem(BRIGHTNESS_KEY) || 'espresso'; } catch(e) {}
    let userDefaults = {};
    try { userDefaults = JSON.parse(localStorage.getItem(USER_DEFAULT_KEY) || '{}'); } catch(e) {}

    const { error } = await _sb.from('schedules').upsert({
      user_id:       _sbUser.id,
      week_data:     weekData,
      accent,
      brightness,
      user_defaults: userDefaults,
      updated_at:    new Date().toISOString(),
    }, { onConflict: 'user_id' });
    setSyncState(error ? 'error' : 'ok');
    if (error) console.warn('[IZ] Push failed:', error.message);
  } catch(e) {
    setSyncState('error');
  }
}

async function pullFromCloud() {
  if (!_sbUser || !_sb) return;
  setSyncState('syncing');
  try {
    const { data, error } = await _sb
      .from('schedules')
      .select('week_data, accent, brightness, user_defaults')
      .eq('user_id', _sbUser.id)
      .single();

    if (error && error.code !== 'PGRST116') {
      console.warn('[IZ] Pull failed:', error.message);
      setSyncState('error');
      return;
    }

    if (!data) {
      // No cloud data yet — push what we have
      pushToCloud();
      return;
    }

    // ── Restore schedule ──────────────────────────────
    const cloudData = data.week_data || {};
    for (let i = 0; i < 7; i++) {
      if (Array.isArray(cloudData[i]) && cloudData[i].length > 0) {
        weekData[i] = cloudData[i];
      }
    }
    normalizeMidnightBlocks();
    for (let i = 0; i < 7; i++) {
      if (!weekData[i] || !Array.isArray(weekData[i]) || weekData[i].length === 0) {
        weekData[i] = getTemplate(i);
      }
      weekData[i].sort((a, b) => sortKey(a) - sortKey(b));
    }
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(weekData)); } catch(e) {}

    // ── Restore theme ─────────────────────────────────
    if (data.accent) {
      try { localStorage.setItem(ACCENT_KEY, data.accent); } catch(e) {}
      applyAccent(data.accent);
    }
    if (data.brightness) {
      try { localStorage.setItem(BRIGHTNESS_KEY, data.brightness); } catch(e) {}
      applyBrightness(data.brightness);
    }

    // ── Restore user defaults ─────────────────────────
    if (data.user_defaults && typeof data.user_defaults === 'object') {
      try { localStorage.setItem(USER_DEFAULT_KEY, JSON.stringify(data.user_defaults)); } catch(e) {}
    }

    renderTabs();
    renderSchedule();
    syncUndoButton();
    syncSaveDefaultButton();
    setSyncState('ok');
    showToast('Settings loaded from cloud ✓');
  } catch(e) {
    setSyncState('error');
    console.warn('[IZ] Pull error:', e);
  }
}

// ─── App versioning ───────────────────────────────────
// Format: 'MAJOR.MINOR.PATCH'
// • MAJOR bump  → breaking change, triggers data validation + possible reset
// • MINOR bump  → new features, data kept, version stamp updated silently
// • PATCH bump  → bug fixes, data kept, version stamp updated silently
// Only the MAJOR number is compared for reset decisions.
const APP_VERSION = '1.0.0';
const VERSION_KEY = 'iz-app-version';

function parseMajor(v) {
  if (!v) return null;
  return parseInt(v.split('.')[0], 10);
}

